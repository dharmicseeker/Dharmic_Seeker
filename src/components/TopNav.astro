---
const { showSidebarButton = false } = Astro.props;
---

<nav id="navbar">

  <div class="nav-left">

    <button
      class="menu-btn"
      onclick="window.openSidebar?.()"
      style={showSidebarButton ? "" : "visibility:hidden"}
    >
      <img src="/menu.png" alt="menu" />
    </button>

    <a href="/" class="nav-logo">

      <div class="logo-wrapper">
        <img class="logo-symbol" src="/logo.png" alt="DharmicSeeker Logo" />
      </div>

      <span class="logo-text">
        DHARMIC<span>SEEKER</span>
      </span>

      </a>

  </div>

  <ul class="nav-links">

    <li><a href="/hinduism/">Hinduism</a></li>

    <li><a href="/buddhism/">Buddhism</a></li>

    <li><a href="/jainism/">Jainism</a></li>

    <li><a href="/sikhism/">Sikhism</a></li>

  </ul>

</nav>

<style>

  :root {
    --gold: #c8941a;
    --gold-bright: #f0c75e;
    --saffron: rgba(242, 136, 0);
    --deep-bg: #07040a;
    --text-primary: #f5f1e8;
    --text-secondary: #cfc7b6;
    --border: rgba(255,255,255,0.08);
    --transition: all 0.3s ease;
  }

#navbar {
  transition: transform 0.3s ease, background 0.3s ease;
  will-change: transform;
}

nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;

  z-index: 100;

  padding: 10px 60px;

  display: grid;
  grid-template-columns: 1fr auto 1fr;

  align-items: center;

  background: linear-gradient(to bottom, rgba(7, 4, 10, 0), transparent);
  box-shadow: 0 1px 0 var(--border);
  backdrop-filter: blur(0px);

  transition: var(--transition);

  min-height: 32px; /* IMPORTANT FIX */
}

  nav.scrolled {
    will-change: background, transform;
    background: rgba(7, 4, 10, 0.50);
    box-shadow: 0 1px 0 var(--border);
    padding: 10px 60px;
  }

  .nav-left {
    display: flex;
    align-items: center;
    gap: 1rem;
    min-width: 140px;
  }

  .menu-btn {

    width: 32px;
    height: 32px;

    background: none;
    border: none;

    cursor: pointer;

    display: flex;


    padding: 2px;
    margin-right: 10px;
    
    margin-left: clamp(-15px, -1vw, 0px);
    transition: var(--transition);
  }

  .menu-btn img {

    width: 26px;
    height: 26px;

    object-fit: contain;

    filter: brightness(1.2);

    transition: transform 0.2s ease;
  }

  .menu-btn:hover img {
    transform: scale(1.1);
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 12px;

    text-decoration: none;

    color: inherit;

    cursor: pointer;
  }

  .nav-logo:hover .logo-symbol {
    transform: scale(1.04);
  }

  .logo-wrapper {
    position: relative;
    width: 42px;
    height: 42px;
  }

  .logo-symbol {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    display: block;
    box-shadow: 0 0 20px rgba(200,148,26,0.35);
    transition: transform 0.25s ease;
  }

  .logo-text {
    font-family: 'Cinzel', serif;

    font-size: 16px;

    font-weight: 700;

    letter-spacing: 0.1em;

    color: var(--text-primary);
  }

  .logo-text span {

    color: rgba(255,136,0);

    margin-left: 2px;

    text-shadow:
      0 0 8px rgba(255,136,0,0.25);
  }

  .nav-links {

    display: flex;

    justify-content: center;

    align-items: center;

    gap: 42px;

    list-style: none;
  }

  .nav-left {
    justify-self: start;
  }

  .nav-links {
    justify-self: center;
  }

  .nav-links a {

    position: relative;

    font-family: 'Cinzel', serif;

    font-size: 11px;

    letter-spacing: 0.18em;

    color: var(--text-secondary);

    text-decoration: none;

    transition: var(--transition);

    padding-bottom: 6px;
  }

  .nav-links a::after {

    content: '';

    position: absolute;

    left: 0;
    bottom: 0;

    width: 0%;
    height: 1px;

    background: var(--gold-bright);

    transition: width 0.35s ease;
  }

  .nav-links a:hover {

    color: var(--gold-bright);

    text-shadow:
      0 0 8px rgba(240,199,94,0.5);
  }

  .nav-links a:hover::after {
    width: 100%;
  }

  @media (max-width: 1200px) {
    
    nav.center-logo .nav-logo {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
    }
    
    nav {
      padding: 10px 16px;
      grid-template-columns: auto 1fr;
      min-height: 64px;
    }

    .nav-links {
      display: none;
    }

    .nav-left {
      justify-self: start;
    }

    .nav-logo {
      gap: 8px;
    }

  .logo-text {

    font-family: 'Cinzel', serif;

    font-size: 1.35rem;

    font-weight: 700;

    letter-spacing: 0.08em;

    color: var(--text-primary);

    line-height: 1;

    white-space: nowrap;

    text-shadow:
      0 0 12px rgba(255,255,255,0.05);
  }

  }

</style>

<script>

const navbar = document.getElementById("navbar");

let lastScrollY = window.scrollY;

function updateNav() {
  const currentScrollY = window.scrollY;

  if (!navbar) return;

  // ── YOUR EXISTING LOGIC ──
  if (currentScrollY > 40) {
    navbar.classList.add("scrolled");
    navbar.classList.add("center-logo");
  } else {
    navbar.classList.remove("scrolled");
    navbar.classList.remove("center-logo");
  }

  // ── NEW: hide on scroll down, show on scroll up ──
  if (currentScrollY > lastScrollY && currentScrollY > 80) {
    // scrolling down
    navbar.style.transform = "translateY(-100%)";
  } else {
    // scrolling up
    navbar.style.transform = "translateY(0)";
  }

  lastScrollY = currentScrollY;
}

window.addEventListener("scroll", updateNav);
window.addEventListener("load", updateNav);

</script>