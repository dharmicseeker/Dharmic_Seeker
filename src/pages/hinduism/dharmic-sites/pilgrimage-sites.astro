    align-items:start;
  }
  @media(max-width:768px){ .two-col{grid-template-columns:1fr;gap:2rem;} }

  /* ── CONCEPT CARDS ── */
  .concept-grid {
    display:grid;
    grid-template-columns:repeat(auto-fill, minmax(260px,1fr));
    gap:1.5rem;
    margin-top:2rem;
  }
  .concept-card {
