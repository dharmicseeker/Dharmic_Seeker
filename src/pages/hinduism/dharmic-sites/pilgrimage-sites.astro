  /* ── TIMELINE ── */
  .timeline { position:relative; margin:3rem 0; }
  .timeline::before {
    content:'';
    position:absolute;
    left:50%; top:0; bottom:0;
    width:1px;
    background:linear-gradient(to bottom, transparent, var(--gold), var(--saffron), transparent);
