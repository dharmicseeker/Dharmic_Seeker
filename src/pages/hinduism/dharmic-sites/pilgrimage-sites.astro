    font-size:1.05rem;
    color:var(--text-secondary);
    line-height:1.9;
    margin-bottom:.75rem;
  }
  .quote-source {
    font-family:'Cinzel', serif;
    font-size:.7rem;
    letter-spacing:.12em;
    color:var(--text-muted);
    text-transform:uppercase;
  }

  /* ── DYNASTY TABLE ── */
  .data-table {
    width:100%;
    border-collapse:collapse;
    margin:2rem 0;
    font-size:.88rem;
  }
  .data-table th {
    background:var(--dark-card);
    font-family:'Cinzel', serif;
    font-size:.7rem;
    letter-spacing:.1em;
    text-transform:uppercase;
    color:var(--gold);
    padding:.75rem 1rem;
    text-align:left;
    border-bottom:2px solid var(--dark-border);
    white-space:nowrap;
  }
  .data-table td {
    padding:.65rem 1rem;
    border-bottom:1px solid rgba(58,37,16,.3);
    color:var(--text-secondary);
    vertical-align:top;
  }
  .data-table tr:hover td { background:rgba(201,168,76,.03); }
  .data-table .highlight { color:var(--gold); font-family:'Cinzel', serif; font-size:.82rem; }

  /* ── ACCORDION ── */
  .accordion { margin:1rem 0; }
  .acc-item { border:1px solid var(--dark-border); border-radius:4px; margin-bottom:.75rem; overflow:hidden; }
  .acc-trigger {
    width:100%;
    background:var(--dark-card);
    border:none;
    padding:1rem 1.5rem;
    display:flex;
    align-items:center;
    justify-content:space-between;
    cursor:pointer;
    font-family:'Cinzel', serif;
    font-size:.9rem;
    color:var(--gold-pale);
    letter-spacing:.03em;
    transition:background .2s;
    text-align:left;
  }
  .acc-trigger:hover { background:rgba(201,168,76,.07); }
  .acc-arrow { color:var(--gold); transition:transform .3s; flex-shrink:0; }
  .acc-trigger.open .acc-arrow { transform:rotate(180deg); }
  .acc-content {
    display:none;
    padding:1.25rem 1.5rem;
    background:rgba(0,0,0,.25);
    font-size:.9rem;
    color:var(--text-secondary);
    line-height:1.85;
    border-top:1px solid var(--dark-border);
  }
  .acc-content.open { display:block; }
  .acc-content ul { padding-left:1.5rem; }
  .acc-content li { margin-bottom:.4rem; }
  .acc-content strong { color:var(--gold); }

  /* ── MAP PLACEHOLDER ── */
  .map-placeholder {
    border:1px dashed var(--dark-border);
    border-radius:4px;
    background:var(--dark-card);
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    padding:4rem 2rem;
    text-align:center;
    position:relative;
    overflow:hidden;
  }
  .map-placeholder::before {
    content:'';
    position:absolute;
    inset:0;
    background:
      repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(58,37,16,.3) 39px, rgba(58,37,16,.3) 40px),
      repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(58,37,16,.3) 39px, rgba(58,37,16,.3) 40px);
  }
  .map-icon { font-size:3rem; margin-bottom:1rem; position:relative; z-index:1; }
  .map-title { font-family:'Cinzel', serif; color:var(--gold); font-size:1.1rem; margin-bottom:.5rem; position:relative; z-index:1; }
  .map-sub { color:var(--text-muted); font-size:.85rem; position:relative; z-index:1; }

  /* ── INFO BADGE ── */
  .badge {
    display:inline-block;
    font-family:'Cinzel', serif;
    font-size:.65rem;
    letter-spacing:.1em;
    text-transform:uppercase;
    padding:.25rem .75rem;
    border-radius:2px;
    margin:.2rem;
  }
  .badge-gold { background:rgba(201,168,76,.15); color:var(--gold); border:1px solid rgba(201,168,76,.3); }
  .badge-crimson { background:rgba(139,26,26,.15); color:#E07070; border:1px solid rgba(139,26,26,.3); }
  .badge-saffron { background:rgba(224,123,46,.1); color:var(--saffron-pale); border:1px solid rgba(224,123,46,.25); }

  /* ── SPECIAL SECTION ── */
  .highlight-section {
    background:linear-gradient(135deg, rgba(201,168,76,.06), rgba(224,123,46,.04));
    border:1px solid rgba(201,168,76,.2);
    border-radius:4px;
    padding:2.5rem;
    margin:2rem 0;
    position:relative;
    overflow:hidden;
  }
  .highlight-section::after {
    content:'';
    position:absolute;
    top:0; right:0;
    width:200px; height:200px;
    background:radial-gradient(circle, rgba(201,168,76,.08), transparent);
    pointer-events:none;
  }

  /* ── PILGRIMAGE ROUTE CARD ── */
  .route-card {
    background:var(--dark-card);
    border:1px solid var(--dark-border);
    border-radius:4px;
    padding:1.75rem;
    margin-bottom:1.5rem;
    position:relative;
    padding-left:4rem;
  }
  .route-number {
    position:absolute;
    left:1.25rem; top:1.75rem;
    font-family:'Cinzel Decorative', serif;
    font-size:1.4rem;
    color:var(--gold);
    opacity:.5;
    line-height:1;
  }
  .route-name {
    font-family:'Cinzel', serif;
    color:var(--gold-pale);
    font-size:1rem;
    margin-bottom:.4rem;
  }
  .route-stops { color:var(--text-muted); font-size:.85rem; font-style:italic; margin-bottom:.75rem; }
  .route-desc { color:var(--text-secondary); font-size:.9rem; line-height:1.8; }

  
  /* ── SEARCH BAR ── */
  .search-bar {
    display:flex;
    gap:1rem;
    margin-bottom:2rem;
    max-width:600px;
  }
  .search-input {
    flex:1;
    background:var(--dark-card);
    border:1px solid var(--dark-border);
    color:var(--text-primary);
    padding:.75rem 1.25rem;
    font-family:'EB Garamond', serif;
    font-size:1rem;
    border-radius:4px;
    outline:none;
    transition:border-color .3s;
  }
  .search-input:focus { border-color:var(--gold); }
  .search-input::placeholder { color:var(--text-muted); }
  .search-btn {
    background:var(--gold);
    border:none;
    color:var(--dark);
    padding:.75rem 1.5rem;
    font-family:'Cinzel', serif;
    font-size:.75rem;
    letter-spacing:.1em;
    text-transform:uppercase;
    border-radius:4px;
    cursor:pointer;
    transition:background .3s;
  }
  .search-btn:hover { background:var(--gold-light); }

  /* ── FILTER TAGS ── */
  .filter-tags { display:flex; gap:.75rem; flex-wrap:wrap; margin-bottom:2rem; }
  .filter-tag {
    background:var(--dark-card);
    border:1px solid var(--dark-border);
    color:var(--text-muted);
    padding:.35rem 1rem;
    font-family:'Cinzel', serif;
    font-size:.7rem;
    letter-spacing:.08em;
    text-transform:uppercase;
    border-radius:2px;
    cursor:pointer;
    transition:all .2s;
  }
  .filter-tag:hover, .filter-tag.active { background:rgba(201,168,76,.1); border-color:var(--gold); color:var(--gold); }

  /* ── RESPONSIVE ── */
  @media(max-width:768px){
    .nav-links { display:none; }
    .hero-stats { gap:1.5rem; }
    .cards-grid { grid-template-columns:1fr; }
    .data-table { font-size:.78rem; }
    .data-table th, .data-table td { padding:.5rem .75rem; }
  }

  /* ── GLOW TEXT ── */
  .glow { text-shadow: 0 0 40px rgba(201,168,76,.4); }
  .text-gold { color:var(--gold); }
  .text-saffron { color:var(--saffron); }
  p + p { margin-top:1rem; }
  .spacer { height:1px; }
</style>


<script>
  // ── Card expand/collapse ──
  function toggleCard(btn) {
    const details = btn.nextElementSibling;
    const arrow = btn.querySelector('.acc-arrow');
    const isOpen = details.classList.toggle('open');
    btn.querySelector('span:first-child').textContent = isOpen ? 'Collapse' : 'Expand Full History';
    arrow.style.transform = isOpen ? 'rotate(180deg)' : '';
  }

  // ── Accordion ──
  function toggleAcc(btn) {
    const content = btn.nextElementSibling;
    const isOpen = content.classList.toggle('open');
    btn.classList.toggle('open', isOpen);
  }

  // ── Search filter ──
  let currentFilter = 'all';
  function setFilter(el, region) {
    document.querySelectorAll('.filter-tag').forEach(t => t.classList.remove('active'));
    el.classList.add('active');
    currentFilter = region;
    filterCards();
  }
  function filterCards() {
    const query = document.getElementById('shaktiSearch').value.toLowerCase();
    document.querySelectorAll('#shaktiGrid .temple-card').forEach(card => {
      const text = card.textContent.toLowerCase();
      const regionMatch = currentFilter === 'all' || card.dataset.region === currentFilter;
      const textMatch = !query || text.includes(query);
      card.style.display = (regionMatch && textMatch) ? '' : 'none';
    });
  }

  // ── Scroll-reveal animation ──
  const revealObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.style.opacity = '1';
        e.target.style.transform = 'translateY(0)';
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.temple-card, .concept-card, .route-card, .timeline-item').forEach(el => {
    el.style.opacity = '0';
    el.style.transform = 'translateY(20px)';
    el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
    revealObs.observe(el);
  });

  // ── Animated stat counters ──
  function animateCounter(el, target, duration = 2000) {
    let start = 0;
    const step = target / (duration / 16);
    const interval = setInterval(() => {
      start = Math.min(start + step, target);
      el.textContent = Math.floor(start) + (target > 100 ? '+' : '');
      if (start >= target) clearInterval(interval);
    }, 16);
  }

  const statsObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        const nums = [51, 12, 5000, 7];
        document.querySelectorAll('.stat-number').forEach((el, i) => {
          animateCounter(el, nums[i]);
        });
        statsObs.disconnect();
      }
    });
  }, { threshold: 0.5 });
  const firstStat = document.querySelector('.hero-stats');
  if (firstStat) statsObs.observe(firstStat);
</script>
