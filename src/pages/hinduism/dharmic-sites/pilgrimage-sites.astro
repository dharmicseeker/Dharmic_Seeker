    overflow:hidden;
    background: radial-gradient(ellipse at 50% 60%, #2A1205 0%, #0A0704 70%);
  }
  .hero-rays {
    position:absolute;
    inset:0;
    background: conic-gradient(from 180deg at 50% 110%,
      transparent 0deg,
      rgba(201,168,76,.04) 15deg,
      transparent 30deg,
      rgba(201,168,76,.03) 45deg,
      transparent 60deg,
      rgba(224,123,46,.04) 90deg,
      transparent 120deg,
      rgba(201,168,76,.03) 150deg,
      transparent 180deg
    );
