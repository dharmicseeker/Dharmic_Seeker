}

.hero-stat-label {
  font-size: 0.75rem;
  color: var(--text-muted);
  letter-spacing: 0.15em;
  text-transform: uppercase;
  font-family: 'Cinzel', serif;
}

.hero-cta {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  background: linear-gradient(135deg, var(--gold-dim), var(--gold));
  color: var(--ink);
  text-decoration: none;
  font-family: 'Cinzel', serif;
  font-size: 0.85rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  padding: 1rem 2.5rem;
  border: none;
  cursor: pointer;
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}

.hero-cta::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, var(--gold), var(--gold-light));
  opacity: 0;
  transition: opacity 0.3s;
}

.hero-cta:hover::before { opacity: 1; }
.hero-cta span { position: relative; z-index: 1; }

.divider-om {
  text-align: center;
  padding: 2rem 0;
  color: var(--gold-dim);
  font-size: 1.5rem;
  font-family: 'Noto Serif Devanagari', serif;
  position: relative;
}

.divider-om::before, .divider-om::after {
  content: '';
  position: absolute;
  top: 50%;
  width: 35%;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--border-bright));
}

.divider-om::before { left: 5%; }
.divider-om::after { right: 5%; background: linear-gradient(90deg, var(--border-bright), transparent); }

/* ─── SECTIONS ─── */
section { padding: 6rem 2rem; }

.section-inner {
  max-width: 1300px;
  margin: 0 auto;
}

.section-header {
  text-align: center;
  margin-bottom: 5rem;
}

.section-tag {
  font-family: 'Cinzel', serif;
  font-size: 0.7rem;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--saffron);
  display: block;
  margin-bottom: 1rem;
}

.section-title {
  font-family: 'Cinzel Decorative', serif;
  font-size: clamp(1.8rem, 4vw, 3rem);
  color: var(--gold-light);
  margin-bottom: 1rem;
  line-height: 1.2;
}

.section-subtitle {
  font-size: 1.1rem;
  font-style: italic;
  color: var(--text-muted);
  max-width: 600px;
  margin: 0 auto;
}

/* ─── INTRODUCTION SECTION ─── */
#intro {
  background: var(--bg-secondary);
}

.intro-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5rem;
  align-items: start;
  margin-bottom: 5rem;
}

.intro-text h3 {
  font-family: 'Cinzel', serif;
  font-size: 1.3rem;
  color: var(--gold);
  margin-bottom: 1.2rem;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid var(--border);
}

.intro-text p {
  color: var(--text-secondary);
  line-height: 2;
  margin-bottom: 1.2rem;
}

.intro-text .sanskrit {
  font-family: 'Noto Serif Devanagari', serif;
  font-size: 1.3rem;
  color: var(--gold-dim);
  display: block;
  text-align: center;
  margin: 1rem 0;
  font-style: italic;
}

.intro-text .translation {
  font-style: italic;
  color: var(--text-muted);
  font-size: 0.95rem;
  text-align: center;
  display: block;
  margin-bottom: 1rem;
}

/* ─── TERMINOLOGY CARDS ─── */
.terminology-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1.5rem;
  margin-top: 3rem;
}

.term-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  padding: 1.8rem;
  position: relative;
  transition: border-color 0.3s, transform 0.3s;
  cursor: default;
}

.term-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, var(--glow), transparent);
  opacity: 0;
  transition: opacity 0.3s;
}

.term-card:hover {
  border-color: var(--border-bright);
  transform: translateY(-2px);
}

.term-card:hover::before { opacity: 1; }

.term-sanskrit {
  font-family: 'Noto Serif Devanagari', serif;
  font-size: 1.6rem;
  color: var(--gold);
  display: block;
  margin-bottom: 0.3rem;
}

.term-name {
  font-family: 'Cinzel', serif;
  font-size: 0.9rem;
  color: var(--saffron);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  display: block;
  margin-bottom: 0.8rem;
}

.term-desc {
  font-size: 0.95rem;
  color: var(--text-secondary);
  line-height: 1.7;
  position: relative;
}

/* ─── ARCHITECTURE STYLES ─── */
#architecture {
  background: var(--bg-primary);
}

.arch-comparison {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
  margin-top: 3rem;
}

.arch-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  overflow: hidden;
  transition: all 0.4s;
}

.arch-card:hover {
  border-color: var(--gold-dim);
  transform: translateY(-4px);
  box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 40px rgba(201, 168, 76, 0.08);
}

.arch-visual {
  height: 220px;
  background: var(--bg-elevated);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

/* SVG Temple Silhouettes */
.nagara-svg, .dravidian-svg, .vesara-svg {
  width: 100%;
  height: 100%;
}

.arch-body {
  padding: 2rem;
}

.arch-title {
  font-family: 'Cinzel', serif;
  font-size: 1.2rem;
  color: var(--gold);
  margin-bottom: 0.3rem;
}

.arch-sub {
  font-family: 'Noto Serif Devanagari', serif;
  font-size: 0.9rem;
  color: var(--gold-dim);
  display: block;
  margin-bottom: 1rem;
}

.arch-body p {
  font-size: 0.95rem;
  color: var(--text-secondary);
  line-height: 1.8;
  margin-bottom: 1rem;
}

.arch-features {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}

.arch-features li {
  font-size: 0.85rem;
  color: var(--text-muted);
  padding-left: 1.2rem;
  position: relative;
}

.arch-features li::before {
  content: '◆';
  position: absolute;
  left: 0;
  color: var(--gold-dim);
  font-size: 0.5rem;
  top: 0.35rem;
}

.arch-examples {
  margin-top: 1rem;
  padding-top: 1rem;
  border-top: 1px solid var(--border);
}

.arch-example-label {
  font-family: 'Cinzel', serif;
  font-size: 0.65rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--saffron);
  display: block;
  margin-bottom: 0.4rem;
}

.arch-examples span {
  font-size: 0.85rem;
  color: var(--text-muted);
  font-style: italic;
}

/* ─── TEMPLE CARDS ─── */
#temples {
  background: var(--bg-secondary);
}

.temple-filter {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  justify-content: center;
  margin-bottom: 3rem;
}

.filter-btn {
  background: none;
  border: 1px solid var(--border);
  color: var(--text-muted);
  font-family: 'Cinzel', serif;
  font-size: 0.7rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  padding: 0.6rem 1.4rem;
  cursor: pointer;
  transition: all 0.3s;
}

.filter-btn:hover, .filter-btn.active {
  border-color: var(--gold);
  color: var(--gold);
  background: rgba(201, 168, 76, 0.06);
}

.temples-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
  gap: 2rem;
}

.temple-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  overflow: hidden;
  transition: all 0.4s;
  position: relative;
}

.temple-card:hover {
  border-color: var(--border-bright);
  transform: translateY(-3px);
  box-shadow: 0 25px 70px rgba(0,0,0,0.6), 0 0 50px rgba(201, 168, 76, 0.06);
}

.temple-header {
  background: linear-gradient(135deg, var(--bg-elevated), var(--stone));
  padding: 2rem;
  border-bottom: 1px solid var(--border);
  position: relative;
  overflow: hidden;
}

.temple-header::after {
  content: '';
  position: absolute;
  top: -20px; right: -20px;
  width: 100px; height: 100px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(201,168,76,0.08) 0%, transparent 70%);
}

.temple-badge {
  display: inline-flex;
  gap: 0.5rem;
  margin-bottom: 0.8rem;
}

.badge {
  font-family: 'Cinzel', serif;
  font-size: 0.6rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  padding: 0.25rem 0.8rem;
  border: 1px solid;
}

.badge-shaiva { color: #C0392B; border-color: rgba(192, 57, 43, 0.4); background: rgba(192, 57, 43, 0.08); }
.badge-vaishnava { color: #2980B9; border-color: rgba(41, 128, 185, 0.4); background: rgba(41, 128, 185, 0.08); }
.badge-shakta { color: #8E44AD; border-color: rgba(142, 68, 173, 0.4); background: rgba(142, 68, 173, 0.08); }
.badge-saura { color: #E67E22; border-color: rgba(230, 126, 34, 0.4); background: rgba(230, 126, 34, 0.08); }
.badge-jain { color: #27AE60; border-color: rgba(39, 174, 96, 0.4); background: rgba(39, 174, 96, 0.08); }
.badge-nagara { color: var(--gold-dim); border-color: rgba(201,168,76,0.3); background: rgba(201,168,76,0.06); }
.badge-dravidian { color: #E74C3C; border-color: rgba(231, 76, 60, 0.3); background: rgba(231, 76, 60, 0.06); }
.badge-mystery { color: #9B59B6; border-color: rgba(155, 89, 182, 0.4); background: rgba(155, 89, 182, 0.08); }
.badge-destroyed { color: #E74C3C; border-color: rgba(231, 76, 60, 0.5); background: rgba(231, 76, 60, 0.1); }

.temple-name {
  font-family: 'Cinzel Decorative', serif;
  font-size: 1.2rem;
  color: var(--gold-light);
  line-height: 1.3;
  margin-bottom: 0.3rem;
}

.temple-devanagari {
  font-family: 'Noto Serif Devanagari', serif;
  font-size: 1rem;
  color: var(--gold-dim);
  display: block;
  margin-bottom: 0.5rem;
}

.temple-location {
  font-size: 0.85rem;
  color: var(--text-muted);
  display: flex;
  align-items: center;
  gap: 0.4rem;
}

.temple-location svg { width: 12px; height: 12px; fill: var(--gold-dim); }

.temple-body {
  padding: 2rem;
}

.temple-meta {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
  margin-bottom: 1.5rem;
}

.meta-item {}

.meta-label {
  font-family: 'Cinzel', serif;
  font-size: 0.6rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--saffron);
  display: block;
  margin-bottom: 0.2rem;
}

.meta-value {
  font-size: 0.9rem;
  color: var(--text-secondary);
}

.temple-section {
  margin-bottom: 1.5rem;
}

.temple-section-title {
  font-family: 'Cinzel', serif;
  font-size: 0.7rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--gold-dim);
  margin-bottom: 0.6rem;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.temple-section-title::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--border);
}

.temple-section p {
  font-size: 0.95rem;
  color: var(--text-secondary);
  line-height: 1.8;
}

.temple-accordion {
  border-top: 1px solid var(--border);
}

.accordion-item {
  border-bottom: 1px solid var(--border);
}

.accordion-trigger {
  width: 100%;
  background: none;
  border: none;
  padding: 1rem 2rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: var(--text-secondary);
  font-family: 'Cinzel', serif;
  font-size: 0.75rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  cursor: pointer;
  transition: color 0.3s;
  text-align: left;
}

.accordion-trigger:hover { color: var(--gold); }

.accordion-trigger .icon {
  transition: transform 0.3s;
  color: var(--gold-dim);
  font-size: 1rem;
}

.accordion-trigger.open .icon { transform: rotate(45deg); }

.accordion-content {
  display: none;
  padding: 0 2rem 1.5rem;
}

.accordion-content.open { display: block; }

.accordion-content p {
  font-size: 0.95rem;
  color: var(--text-secondary);
  line-height: 1.8;
  margin-bottom: 0.8rem;
}

.accordion-content ul {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}

.accordion-content ul li {
  font-size: 0.9rem;
  color: var(--text-muted);
  padding-left: 1.2rem;
  position: relative;
}

.accordion-content ul li::before {
  content: '◈';
  position: absolute;
  left: 0;
  color: var(--gold-dim);
  font-size: 0.6rem;
  top: 0.35rem;
}

.highlight-box {
  background: rgba(201, 168, 76, 0.06);
  border-left: 3px solid var(--gold-dim);
  padding: 1rem 1.5rem;
  margin: 1rem 0;
  font-size: 0.9rem;
  color: var(--text-secondary);
  font-style: italic;
}

.danger-box {
  background: rgba(231, 76, 60, 0.06);
  border-left: 3px solid #c0392b;
  padding: 1rem 1.5rem;
  margin: 1rem 0;
  font-size: 0.9rem;
  color: #c9a8a8;
}

/* ─── TIMELINE ─── */
#timeline {
  background: var(--bg-primary);
}

.timeline {
  position: relative;
  max-width: 900px;
  margin: 0 auto;
}

.timeline::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 0; bottom: 0;
  width: 1px;
  background: linear-gradient(to bottom, transparent, var(--border-bright) 10%, var(--border-bright) 90%, transparent);
  transform: translateX(-50%);
}

.timeline-item {
  display: flex;
  align-items: flex-start;
  gap: 3rem;
  margin-bottom: 3rem;
  position: relative;
}

.timeline-item:nth-child(even) {
  flex-direction: row-reverse;
}

.timeline-item:nth-child(even) .timeline-content {
  text-align: right;
}

.timeline-date {
  font-family: 'Cinzel', serif;
  font-size: 0.8rem;
  color: var(--gold);
  white-space: nowrap;
  flex: 1;
  text-align: right;
  padding-top: 0.2rem;
}

.timeline-item:nth-child(even) .timeline-date { text-align: left; }

.timeline-dot {
  width: 14px;
  height: 14px;
  border-radius: 50%;
  background: var(--gold);
  border: 3px solid var(--bg-primary);
  box-shadow: 0 0 0 1px var(--gold-dim), 0 0 20px rgba(201, 168, 76, 0.3);
  flex-shrink: 0;
  margin-top: 0.25rem;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

.timeline-content {
  flex: 1;
  background: var(--bg-card);
  border: 1px solid var(--border);
  padding: 1.5rem;
}

.timeline-content h4 {
  font-family: 'Cinzel', serif;
  font-size: 0.95rem;
  color: var(--gold-light);
  margin-bottom: 0.5rem;
}

.timeline-content p {
  font-size: 0.9rem;
  color: var(--text-muted);
  line-height: 1.7;
}

.timeline-dot.destruction { background: #c0392b; box-shadow: 0 0 0 1px #8b1a1a, 0 0 20px rgba(192, 57, 43, 0.4); }
.timeline-dot.rebuild { background: #27ae60; box-shadow: 0 0 0 1px #1a6b3a, 0 0 20px rgba(39, 174, 96, 0.4); }

/* ─── ENGINEERING SECTION ─── */
#engineering {
  background: var(--bg-secondary);
}

.engineering-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 2rem;
}

.eng-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  padding: 2rem;
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}

.eng-card::before {
  content: attr(data-num);
  position: absolute;
  top: -0.5rem; right: 1rem;
  font-family: 'Cinzel Decorative', serif;
  font-size: 5rem;
  color: var(--gold);
  opacity: 0.04;
  line-height: 1;
}

.eng-card:hover {
  border-color: var(--gold-dim);
  transform: translateY(-3px);
}

.eng-icon {
  font-size: 2.5rem;
  margin-bottom: 1rem;
  display: block;
}

.eng-title {
  font-family: 'Cinzel', serif;
  font-size: 1rem;
  color: var(--gold);
  margin-bottom: 0.8rem;
}

.eng-card p {
  font-size: 0.9rem;
  color: var(--text-secondary);
  line-height: 1.8;
}

.eng-temple {
  margin-top: 1rem;
  padding-top: 0.8rem;
  border-top: 1px solid var(--border);
  font-size: 0.8rem;
  color: var(--text-muted);
  font-style: italic;
}

/* ─── MYSTERIES SECTION ─── */
#mysteries {
  background: var(--bg-primary);
  position: relative;
}

#mysteries::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 60% 60% at 50% 50%, rgba(107, 26, 26, 0.06) 0%, transparent 70%);
  pointer-events: none;
}

.mystery-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
  gap: 2rem;
}

.mystery-card {
  background: var(--bg-card);
  border: 1px solid rgba(142, 68, 173, 0.2);
  padding: 2rem;
  position: relative;
  transition: all 0.3s;
}

.mystery-card:hover {
  border-color: rgba(142, 68, 173, 0.5);
  box-shadow: 0 0 40px rgba(142, 68, 173, 0.06);
}

.mystery-num {
  font-family: 'Cinzel Decorative', serif;
  font-size: 0.65rem;
  letter-spacing: 0.3em;
  color: #9b59b6;
  text-transform: uppercase;
  display: block;
  margin-bottom: 0.8rem;
}

.mystery-title {
  font-family: 'Cinzel', serif;
  font-size: 1.1rem;
  color: var(--gold-light);
  margin-bottom: 1rem;
}

.mystery-card p {
  font-size: 0.95rem;
  color: var(--text-secondary);
  line-height: 1.8;
}

.mystery-temple {
  margin-top: 1rem;
  font-family: 'Cinzel', serif;
  font-size: 0.7rem;
  color: var(--gold-dim);
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

/* ─── DYNASTIES ─── */
#dynasties {
  background: var(--bg-secondary);
}

.dynasty-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: 2rem;
}

.dynasty-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  padding: 2rem;
  transition: all 0.3s;
}

.dynasty-card:hover {
  border-color: var(--border-bright);
}

.dynasty-era {
  font-family: 'Cinzel', serif;
  font-size: 0.65rem;
  letter-spacing: 0.2em;
  color: var(--saffron);
  text-transform: uppercase;
  display: block;
  margin-bottom: 0.5rem;
}

.dynasty-name {
  font-family: 'Cinzel Decorative', serif;
  font-size: 1.2rem;
  color: var(--gold-light);
  margin-bottom: 1rem;
}

.dynasty-card p {
  font-size: 0.9rem;
  color: var(--text-secondary);
  line-height: 1.8;
  margin-bottom: 1rem;
}

.dynasty-temples {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}

.temple-tag {
  font-size: 0.7rem;
  font-family: 'Cinzel', serif;
  color: var(--gold-dim);
  border: 1px solid var(--border);
  padding: 0.2rem 0.7rem;
  letter-spacing: 0.05em;
}

/* ─── COMPARISON TABLE ─── */
.comparison-wrap {
  overflow-x: auto;
  margin-top: 3rem;
}

.comparison-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.88rem;
}

.comparison-table th {
  background: var(--bg-elevated);
  color: var(--gold);
  font-family: 'Cinzel', serif;
  font-size: 0.7rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  padding: 1rem 1.5rem;
  text-align: left;
  border-bottom: 1px solid var(--border-bright);
  white-space: nowrap;
}

.comparison-table td {
  padding: 1rem 1.5rem;
  border-bottom: 1px solid var(--border);
  color: var(--text-secondary);
  vertical-align: top;
}

.comparison-table tr:hover td {
  background: rgba(201, 168, 76, 0.03);
}

.comparison-table td:first-child {
  font-family: 'Cinzel', serif;
  font-size: 0.85rem;
  color: var(--gold-light);
  white-space: nowrap;
}

/* ─── GLOSSARY ─── */
#glossary {
  background: var(--bg-primary);
}

.glossary-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 1rem;
}

.glossary-item {
  background: var(--bg-card);
  border: 1px solid var(--border);
  padding: 1.2rem 1.5rem;
  display: flex;
  gap: 1rem;
  align-items: flex-start;
}

.glossary-term {
  font-family: 'Cinzel', serif;
  font-size: 0.9rem;
  color: var(--gold);
  min-width: 120px;
  flex-shrink: 0;
}

.glossary-def {
  font-size: 0.88rem;
  color: var(--text-muted);
  line-height: 1.6;
}

/* ─── FAQ ─── */
#faq {
  background: var(--bg-secondary);
}

.faq-list {
  max-width: 800px;
  margin: 0 auto;
}

.faq-item {
  border: 1px solid var(--border);
  margin-bottom: 1rem;
  background: var(--bg-card);
}

.faq-q {
  width: 100%;
  background: none;
  border: none;
  padding: 1.5rem 2rem;
  color: var(--text-primary);
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.1rem;
  text-align: left;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: color 0.3s;
}

.faq-q:hover { color: var(--gold); }

.faq-q .faq-icon {
  color: var(--gold-dim);
  font-size: 1.4rem;
  flex-shrink: 0;
  transition: transform 0.3s;
}

.faq-q.open .faq-icon { transform: rotate(45deg); }

.faq-a {
  display: none;
  padding: 0 2rem 1.5rem;
  font-size: 0.95rem;
  color: var(--text-secondary);
  line-height: 1.9;
  border-top: 1px solid var(--border);
}

.faq-a.open { display: block; }


/* ─── SPECIAL SECTIONS ─── */
.special-section {
  background: linear-gradient(135deg, var(--bg-card), var(--bg-elevated));
  border: 1px solid var(--border);
  padding: 3rem;
  margin-top: 3rem;
  position: relative;
  overflow: hidden;
}

.special-section::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 4px; height: 100%;
  background: linear-gradient(to bottom, var(--gold), var(--saffron));
}

.special-section-title {
  font-family: 'Cinzel', serif;
  font-size: 1rem;
  color: var(--gold);
  margin-bottom: 1.5rem;
  letter-spacing: 0.1em;
}

/* ─── PILGRIMAGE ROUTES ─── */
.pilgrimage-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  padding: 2rem;
}

.pilgrimage-route {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-top: 1rem;
}

.route-stop {
  font-family: 'Cinzel', serif;
  font-size: 0.75rem;
  color: var(--text-secondary);
  background: rgba(201, 168, 76, 0.06);
  border: 1px solid var(--border);
  padding: 0.4rem 0.8rem;
}

.route-arrow {
  color: var(--gold-dim);
  font-size: 0.8rem;
}

/* ─── SOURCES ─── */
.source-tag {
  display: inline-block;
  font-family: 'Cinzel', serif;
  font-size: 0.6rem;
  letter-spacing: 0.1em;
  color: var(--text-muted);
  background: rgba(201, 168, 76, 0.05);
  border: 1px solid var(--border);
  padding: 0.15rem 0.6rem;
  margin: 0.1rem;
  text-transform: uppercase;
}

/* ─── RESPONSIVE ─── */
@media (max-width: 1024px) {
  .intro-grid { grid-template-columns: 1fr; gap: 3rem; }
  .arch-comparison { grid-template-columns: 1fr; }
  .footer-inner { grid-template-columns: 1fr 1fr; }
}

@media (max-width: 768px) {
  .nav-links, .nav-search { display: none; }
  .hero-stats { gap: 2rem; }
  .temples-grid { grid-template-columns: 1fr; }
  .mystery-grid { grid-template-columns: 1fr; }
  .engineering-grid { grid-template-columns: 1fr; }
  .dynasty-grid { grid-template-columns: 1fr; }
  .timeline::before { left: 20px; }
  .timeline-item { flex-direction: column; padding-left: 50px; }
  .timeline-item:nth-child(even) { flex-direction: column; }
  .timeline-item:nth-child(even) .timeline-content { text-align: left; }
  .timeline-item:nth-child(even) .timeline-date { text-align: left; }
  .timeline-dot { left: 20px; }
  .timeline-date { font-size: 0.75rem; }
  .footer-inner { grid-template-columns: 1fr; }
  section { padding: 4rem 1.5rem; }
  .arch-comparison { grid-template-columns: 1fr; }
  .terminology-grid { grid-template-columns: 1fr; }
}

/* ─── ANIMATIONS ─── */
.fade-in {
  opacity: 0;
  transform: translateY(20px);
  animation: fadeInUp 0.8s ease forwards;
}

@keyframes fadeInUp {
  to { opacity: 1; transform: translateY(0); }
}

.fade-in:nth-child(1) { animation-delay: 0.1s; }
.fade-in:nth-child(2) { animation-delay: 0.2s; }
.fade-in:nth-child(3) { animation-delay: 0.3s; }
.fade-in:nth-child(4) { animation-delay: 0.4s; }

/* Scroll reveal */
.reveal {
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.8s ease, transform 0.8s ease;
}

.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

/* Gold shimmer on hover */
.gold-shimmer {
  background: linear-gradient(90deg, var(--gold-dim), var(--gold-light), var(--gold-dim));
  background-size: 200% auto;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.gold-shimmer:hover {
  animation: shimmer 1.5s linear infinite;
}

@keyframes shimmer {
  to { background-position: 200% center; }
}
</style>

<!-- ═══════════════════ JAVASCRIPT ════════════════════════════ -->
<script>
// Accordion
function toggleAccordion(btn) {
  const content = btn.nextElementSibling;
  const isOpen = btn.classList.contains('open');

  // Close all in this card
  const card = btn.closest('.temple-accordion');
  card.querySelectorAll('.accordion-trigger').forEach(t => {
    t.classList.remove('open');
    t.nextElementSibling.classList.remove('open');
  });

  if (!isOpen) {
    btn.classList.add('open');
    content.classList.add('open');
  }
}

// FAQ
function toggleFAQ(btn) {
  const content = btn.nextElementSibling;
  const isOpen = btn.classList.contains('open');

  document.querySelectorAll('.faq-q').forEach(q => {
    q.classList.remove('open');
    q.nextElementSibling.classList.remove('open');
  });

  if (!isOpen) {
    btn.classList.add('open');
    content.classList.add('open');
  }
}

// Filter system
document.querySelectorAll('.filter-btn').forEach(btn => {
  btn.addEventListener('click', function() {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    this.classList.add('active');

    const filter = this.dataset.filter;
    const cards = document.querySelectorAll('.temple-card');

    cards.forEach(card => {
      if (filter === 'all') {
        card.style.display = '';
      } else {
        const tags = card.dataset.tags || '';
        card.style.display = tags.includes(filter) ? '' : 'none';
      }
    });
  });
});

// Search
document.getElementById('searchInput').addEventListener('input', function() {
  const query = this.value.toLowerCase();
  document.querySelectorAll('.temple-card').forEach(card => {
    const text = card.textContent.toLowerCase();
    card.style.display = text.includes(query) ? '' : 'none';
  });
});

// Scroll reveal
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
    }
  });
}, { threshold: 0.1 });

document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

// Active nav link
window.addEventListener('scroll', () => {
  const sections = document.querySelectorAll('section[id], section[id]');
  const scrollY = window.scrollY + 100;

  sections.forEach(section => {
    if (section.offsetTop <= scrollY && section.offsetTop + section.offsetHeight > scrollY) {
      const id = section.id;
      document.querySelectorAll('.nav-links a').forEach(a => {
        a.style.color = a.getAttribute('href') === '#' + id ? 'var(--gold)' : '';
      });
    }
  });
});
</script>
