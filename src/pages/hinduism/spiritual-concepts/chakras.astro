<script>
// ─── CURSOR ───────────────────────────────────
const cursor = document.getElementById('cursor');
const ring = document.getElementById('cursor-ring');
let mx = 0, my = 0, rx = 0, ry = 0;
document.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; });
(function raf() {
  rx += (mx - rx) * 0.12; ry += (my - ry) * 0.12;
  cursor.style.left = mx + 'px'; cursor.style.top = my + 'px';
  ring.style.left = rx + 'px'; ring.style.top = ry + 'px';
  requestAnimationFrame(raf);
})();

// ─── HERO THREE.JS ───────────────────────────
(function initHero() {
  const canvas = document.getElementById('hero-canvas');
  const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.setSize(window.innerWidth, window.innerHeight);
  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 100);
  camera.position.set(0, 0, 5);

  // Ambient
  scene.add(new THREE.AmbientLight(0x2a1a40, 1.5));
  const dirLight = new THREE.DirectionalLight(0xc9a84c, 0.8);
  dirLight.position.set(2, 3, 3);
  scene.add(dirLight);

  // Chakra data
  const cData = [
    { color: 0xff3333, y: -2.4, label: 'Mūlādhāra' },
    { color: 0xff6600, y: -1.6, label: 'Svādhiṣṭhāna' },
    { color: 0xffcc00, y: -0.8, label: 'Maṇipūra' },
    { color: 0x33cc55, y: 0,    label: 'Anāhata' },
    { color: 0x3399ff, y: 0.8,  label: 'Viśuddha' },
    { color: 0x7755dd, y: 1.6,  label: 'Ājñā' },
    { color: 0xc9a84c, y: 2.4,  label: 'Sahasrāra' },
  ];

  const chakraMeshes = [];
  cData.forEach(d => {
    const geo = new THREE.SphereGeometry(0.18, 32, 32);
    const mat = new THREE.MeshPhongMaterial({
      color: d.color, emissive: d.color, emissiveIntensity: 0.4,
      transparent: true, opacity: 0.85
    });
    const mesh = new THREE.Mesh(geo, mat);
    mesh.position.set(0, d.y, 0);
    scene.add(mesh);
    chakraMeshes.push(mesh);

    // Aura ring
    const ringGeo = new THREE.TorusGeometry(0.35, 0.015, 8, 64);
    const ringMat = new THREE.MeshBasicMaterial({ color: d.color, transparent: true, opacity: 0.3 });
    const ring3 = new THREE.Mesh(ringGeo, ringMat);
    ring3.position.copy(mesh.position);
    ring3.rotation.x = Math.PI / 2;
    scene.add(ring3);
    chakraMeshes.push(ring3);
  });

  // Spine line
  const spinePoints = [new THREE.Vector3(0,-2.7,0), new THREE.Vector3(0,2.7,0)];
  const spineGeo = new THREE.BufferGeometry().setFromPoints(spinePoints);
  const spineMat = new THREE.LineBasicMaterial({ color: 0xc9a84c, transparent: true, opacity: 0.15 });
  scene.add(new THREE.Line(spineGeo, spineMat));

  // Particles
  const N = 700;
  const pPos = new Float32Array(N * 3);
  for (let i = 0; i < N; i++) {
    pPos[i*3]   = (Math.random()-0.5)*10;
    pPos[i*3+1] = (Math.random()-0.5)*8;
    pPos[i*3+2] = (Math.random()-0.5)*8 - 2;
  }
  const pGeo = new THREE.BufferGeometry();
  pGeo.setAttribute('position', new THREE.BufferAttribute(pPos, 3));
  const pMat = new THREE.PointsMaterial({ color: 0xc9a84c, size: 0.015, transparent: true, opacity: 0.35 });
  scene.add(new THREE.Points(pGeo, pMat));

  // Sacred geometry — icosahedron wireframe
  const iGeo = new THREE.IcosahedronGeometry(3, 1);
  const iMat = new THREE.MeshBasicMaterial({ color: 0x6b3fa0, wireframe: true, transparent: true, opacity: 0.04 });
  const ico = new THREE.Mesh(iGeo, iMat);
  scene.add(ico);

  let mouseX = 0, mouseY = 0;
  document.addEventListener('mousemove', e => {
    mouseX = (e.clientX / window.innerWidth - 0.5) * 2;
    mouseY = (e.clientY / window.innerHeight - 0.5) * 2;
  });

  window.addEventListener('resize', () => {
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
  });

  let t = 0;
  function animate() {
    requestAnimationFrame(animate);
    t += 0.008;
    camera.position.x += (mouseX * 0.8 - camera.position.x) * 0.04;
    camera.position.y += (-mouseY * 0.4 - camera.position.y) * 0.04;
    camera.lookAt(0, 0, 0);
    ico.rotation.y = t * 0.1;
    ico.rotation.x = t * 0.05;
    cData.forEach((d, i) => {
      const mesh = chakraMeshes[i * 2];
      const ring3 = chakraMeshes[i * 2 + 1];
      const pulse = 1 + Math.sin(t * 1.5 + i * 0.8) * 0.12;
      mesh.scale.setScalar(pulse);
      ring3.scale.setScalar(pulse * 1.05);
      ring3.rotation.y = t * 0.5 + i;
      mesh.material.emissiveIntensity = 0.35 + Math.sin(t * 2 + i) * 0.15;
    });
    renderer.render(scene, camera);
  }
  animate();

  // Animate hero text in
  setTimeout(() => {
    const el = (id, delay) => {
      const e = document.getElementById(id);
      if (!e) return;
      e.style.transition = `opacity 1.2s ${delay}s ease, transform 1.2s ${delay}s ease`;
      e.style.opacity = 1;
      e.style.transform = 'translateY(0)';
    };
    el('hero-title', 0.3);
    el('hero-sub', 0.7);
    el('hero-tagline', 1.1);
    el('hero-btns', 1.5);
    document.getElementById('scroll-ind').style.transition = 'opacity 1s 2.2s ease';
    document.getElementById('scroll-ind').style.opacity = 1;
  }, 400);
})();

