  { name:'Svādhiṣṭhāna', dev:'स्वाधिष्ठान', color:'#ff8800', location:'Sacrum — lower abdomen', domain:'Emotions, creativity, desire, pleasure, relational dynamics', element:'Element: Water (Āpas) · Bīja: Vaṃ' },
  { name:'Maṇipūra', dev:'मणिपूर', color:'#ffc800', location:'Solar plexus — navel region', domain:'Personal power, will, self-esteem, transformation, digestion', element:'Element: Fire (Agni) · Bīja: Raṃ' },
  { name:'Anāhata', dev:'अनाहत', color:'#32c850', location:'Heart center — thoracic spine', domain:'Love, compassion, spaciousness, bridge between body and spirit', element:'Element: Air (Vāyu) · Bīja: Yaṃ' },
  { name:'Viśuddha', dev:'विशुद्ध', color:'#3296ff', location:'Throat — cervical spine', domain:'Communication, authentic expression, integration, inner truth', element:'Element: Ether (Ākāśa) · Bīja: Haṃ' },
  { name:'Ājñā', dev:'आज्ञा', color:'#7755dd', location:'Between the eyebrows', domain:'Intuition, discrimination, witness consciousness, inner command', element:'Element: Mind (Manas) · Bīja: Oṃ' },
  { name:'Sahasrāra', dev:'सहस्रार', color:'#c9a84c', location:'Crown of the head', domain:'Pure consciousness, unity, liberation, union of Śiva and Śakti', element:'Beyond elements · Oṃ / Silence' },
];
const tooltip = document.getElementById('chakra-tooltip');
const ttName = document.getElementById('tt-name');
const ttDev = document.getElementById('tt-devanagari');
const ttLoc = document.getElementById('tt-location');
const ttDomain = document.getElementById('tt-domain');
const ttEl = document.getElementById('tt-element');

document.querySelectorAll('.chakra-pt').forEach(pt => {
  pt.style.cursor = 'pointer';
  pt.addEventListener('mouseenter', function(e) {
    const idx = parseInt(this.dataset.idx);
    const d = ttData[idx];
    ttName.textContent = d.name;
    ttName.style.color = d.color;
    ttDev.textContent = d.dev;
    ttDev.style.color = d.color;
    ttLoc.textContent = d.location;
    ttDomain.textContent = d.domain;
    ttEl.textContent = d.element;
    tooltip.style.display = 'block';
  });
  pt.addEventListener('mousemove', function(e) {
    const rect = document.getElementById('body-map-container').getBoundingClientRect();
    let x = e.clientX - rect.left + 20;
    let y = e.clientY - rect.top + 20;
    if (x + 300 > rect.width) x = e.clientX - rect.left - 300;
    tooltip.style.left = x + 'px';
    tooltip.style.top = y + 'px';
  });
  pt.addEventListener('mouseleave', function() {
    tooltip.style.display = 'none';
  });
  pt.addEventListener('click', function() {
    const idx = parseInt(this.dataset.idx);
    document.querySelectorAll('.chakra-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.chakra-panel').forEach(p => p.classList.remove('active'));
    document.querySelector('.chakra-tab[data-chakra="'+idx+'"]').classList.add('active');
    document.getElementById('panel-'+idx).classList.add('active');
    document.getElementById('chakras').scrollIntoView({ behavior:'smooth' });
  });
});

// ─── SCROLL REVEAL ────────────────────────────
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in-view'); observer.unobserve(e.target); } });
}, { threshold: 0.12 });
document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>
</body>