// Build chakra panels
const panelsContainer = document.getElementById('chakra-panels');
chakras.forEach((c, i) => {
  const glowColor = c.color + '40';
  const div = document.createElement('div');
  div.className = 'chakra-panel' + (i === 0 ? ' active' : '');
  div.id = `panel-${i}`;
  div.innerHTML = `
    <div class="chakra-visual">
      <div class="chakra-orb-wrap">
        <div class="chakra-orb" style="
          background: radial-gradient(circle at 35% 35%, ${c.color}cc, ${c.color}44 60%, transparent);
          box-shadow: 0 0 40px ${c.color}55, 0 0 80px ${c.color}22, inset 0 0 30px rgba(255,255,255,0.08);
          --orb-shadow: 0 0 40px ${c.color}55, 0 0 80px ${c.color}22;
          --orb-shadow-lg: 0 0 60px ${c.color}77, 0 0 120px ${c.color}33;
        ">${c.bija}</div>
      </div>
      <div class="chakra-sanskrit">${c.devanagari}</div>
      <div class="chakra-bija">Bīja: ${c.bijaRoman} &nbsp;·&nbsp; ${c.petals}</div>
      <div class="chakra-attrs">
        ${Object.entries(c.attrs).map(([k,v]) => `
          <div class="chakra-attr">
            <span class="chakra-attr-label">${k}</span>
            <span class="chakra-attr-val">${v}</span>
          </div>
        `).join('')}
      </div>
      <div class="mantra-box">
        <span class="mantra-label">Bīja Mantra</span>
        <span class="mantra-text">${c.bija}</span>
        <span class="mantra-roman">${c.bijaRoman}</span>
      </div>
    </div>
    <div class="chakra-info">
      <h3>${c.name}</h3>
      <div class="chakra-meaning">${c.meaning}</div>
      <p class="chakra-section-head">Psychological Domain</p>
      <p class="chakra-text">${c.psychological}</p>
      <p class="chakra-section-head">Spiritual Significance</p>
      <p class="chakra-text">${c.spiritual}</p>
      <p class="chakra-section-head">Physical Associations</p>
      <p class="chakra-text">${c.physical}</p>
      <p class="chakra-section-head">Meditation Practice</p>
      <p class="chakra-text">${c.meditation}</p>
      <p class="chakra-section-head">Signs of Imbalance</p>
      <p class="chakra-text">${c.blockage}</p>
      <p class="chakra-section-head">Awakening Experiences</p>
      <p class="chakra-text">${c.awakening}</p>
      <p class="chakra-section-head">Scriptural Reference</p>
      <p class="chakra-text" style="font-style:italic;color:rgba(232,213,163,0.7)">${c.scripture}</p>
    </div>
  `;
  panelsContainer.appendChild(div);
});

// Tab switching
document.querySelectorAll('.chakra-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    const idx = tab.dataset.chakra;
    document.querySelectorAll('.chakra-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.chakra-panel').forEach(p => p.classList.remove('active'));
    tab.classList.add('active');
    document.getElementById(`panel-${idx}`).classList.add('active');
  });
});

// ─── FAQ ──────────────────────────────────────
const faqs = [
  { q: 'Are chakras scientifically proven?', a: 'No — not as physical structures. No peer-reviewed study has identified anatomical correlates for chakras. However, this does not mean they are without value. The framework describes subjective experiential phenomena that practitioners across cultures and centuries have consistently reported. Science and contemplative phenomenology are answering different questions with different methods. What neuroscience has confirmed is that sustained meditation produces measurable neurological changes — the causal framework for why remains debated.' },
  { q: 'Is the seven-chakra system the only traditional system?', a: 'No. Different texts describe different numbers. The Yoga Yājñavalkya mentions 14 chakras. Some Tantric texts describe 4, 5, 6, or 9. The Tibetan Buddhist vajra body system has a somewhat analogous but distinct structure. Even within the Tantric tradition, different śākhās (branches) use different frameworks. The seven-chakra rainbow model familiar to Western audiences is largely a codification from the Ṣaṭ-Cakra-Nirūpaṇa and its popularization through early 20th-century Theosophical writers like Charles Leadbeater.' },
  { q: 'Can you forcibly awaken kundalini through intensive practice?', a: 'Traditional texts strongly caution against this. The Yoga Kuṇḍalinī Upaniṣad, Swami Sivananda\'s writings, and modern teachers like Georg Feuerstein all emphasize that kuṇḍalinī awakening without adequate preparation and guidance can produce what contemporary literature calls "kuṇḍalinī syndrome" — a spectrum of disorienting psychological, somatic, and perceptual experiences that can range from uncomfortable to deeply destabilizing. The classical prescription is years of foundational practice (yama-niyama, āsana, prāṇāyāma) before advanced kuṇḍalinī work.' },
  { q: 'Do chakra colors have ancient scriptural authority?', a: 'Mostly, though the modern rainbow correspondence is partially modern. The Ṣaṭ-Cakra-Nirūpaṇa describes specific colors for each chakra, but they differ from the popular rainbow system. For example, Maṇipūra is described as "blue-grey like storm clouds" (not yellow), and Viśuddha as "smoky purple" (not bright blue). The clean rainbow spectrum mapping (red–orange–yellow–green–blue–indigo–violet) appears to be a 20th-century systematization.' },
  { q: 'What is the difference between chakra meditation and ordinary mindfulness?', a: 'Mindfulness practice typically trains broad, non-judgmental awareness of present-moment experience. Chakra meditation involves directed concentration (dhāraṇā) on specific energetic centers, their mantras, yantras, and associated qualities. Classical Yogic texts place chakra practices in the dhāraṇā-dhyāna tier — the sixth and seventh limbs of Patañjali\'s eight-limbed Yoga — which presuppose a stable foundation in āsana and prāṇāyāma. They are more targeted, more technically demanding, and classically require more preparation than open-awareness mindfulness.' },
  { q: 'Is it necessary to be Hindu to work with chakras?', a: 'The practices are technically accessible outside their religious context — just as Japanese Zen techniques are practiced globally outside their Buddhist context. However, divorcing practices from their source tradition involves tradeoffs: the ethical framework (yama-niyama), the cosmological understanding (understanding what the practices are actually doing), and the relational transmission (paramparā) are all lost in decontextualized versions. Practices work differently — and carry different risks — without these safeguards. Engaging with the tradition with genuine respect and intellectual honesty is recommended.' },
];
const faqList = document.getElementById('faq-list');
faqs.forEach(f => {
  const item = document.createElement('div'); item.className = 'faq-item';
  item.innerHTML = `
    <button class="faq-q"><span>${f.q}</span><span class="faq-arrow">+</span></button>
    <div class="faq-a"><div class="faq-a-inner">${f.a}</div></div>
  `;
  faqList.appendChild(item);
  const btn = item.querySelector('.faq-q');
  const ans = item.querySelector('.faq-a');
  btn.addEventListener('click', () => {
    const open = btn.classList.contains('open');
    document.querySelectorAll('.faq-q.open').forEach(b => {
      b.classList.remove('open');
      b.nextElementSibling.style.maxHeight = '0';
    });
    if (!open) {
      btn.classList.add('open');
      ans.style.maxHeight = ans.scrollHeight + 'px';
    }
  });
});

// ─── BODY MAP TOOLTIP ────────────────────────
const ttData = [
