<style>
:root {
  --void: #040408;
  --abyss: #07080F;
  --cosmos: #0B0D1A;
  --deep: #111428;
  --indigo-deep: #181B35;
  --gold: #D4A820;
  --gold-bright: #F0C040;
  --gold-pale: #F5DFA0;
  --amber: #C87820;
  --saffron: #E05010;
  --saffron-lt: #F07030;
  --silver: #C8C8D8;
  --silver-lt: #E0E0F0;
  --rose-divine: #C84060;
  --teal-cosmic: #20A090;
  --violet: #6040A0;
  --ivory: #F8F2E4;
  --text-body: #C8B890;
  --text-muted: #806850;
  --border: rgba(212,168,32,0.25);
  --border-bright: rgba(212,168,32,0.55);
  --glow: rgba(212,168,32,0.15);
}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  font-family:'Cormorant Garamond',Georgia,serif;
  background:var(--void);
  color:var(--text-body);
  overflow-x:hidden;
  line-height:1.8;
  font-size:17px;
}

/* Cosmic canvas */
#cosmos-bg{
  position:fixed;top:0;left:0;width:100%;height:100%;
  pointer-events:none;z-index:0;
  background:
    radial-gradient(ellipse 60% 40% at 15% 25%, rgba(100,60,180,0.08) 0%, transparent 60%),
    radial-gradient(ellipse 50% 60% at 85% 70%, rgba(200,120,32,0.06) 0%, transparent 60%),
    radial-gradient(ellipse 80% 80% at 50% 50%, rgba(11,13,26,0.95) 0%, var(--void) 100%);
}

/* ===== HERO ===== */
#hero{
  position:relative;min-height:100vh;
  display:flex;align-items:center;justify-content:center;
  text-align:center;padding:7rem 2rem 4rem;
  overflow:hidden;
}
.hero-mandala{
  position:absolute;top:50%;left:50%;
  transform:translate(-50%,-50%);
  width:min(90vw,780px);height:min(90vw,780px);
  opacity:0.055;
  animation:slow-spin 180s linear infinite;
}
@keyframes slow-spin{to{transform:translate(-50%,-50%) rotate(360deg)}}
.hero-inner{position:relative;z-index:2;max-width:860px}
.hero-deva{
  font-family:'Noto Serif Devanagari',serif;
  font-size:clamp(1.4rem,4vw,2.4rem);
  color:var(--gold);letter-spacing:0.08em;
  margin-bottom:1.2rem;opacity:0.9;
  text-shadow:0 0 40px rgba(212,168,32,0.5);
}
.hero-tag{
  font-family:'Cinzel',serif;
  font-size:0.65rem;letter-spacing:0.5em;text-transform:uppercase;
  color:var(--saffron-lt);margin-bottom:1.8rem;
}
h1.hero-h1{
  font-family:'Cinzel',serif;
  font-size:clamp(2rem,6vw,4.8rem);
  font-weight:900;line-height:1.05;
  color:var(--gold-bright);
  text-shadow:0 0 80px rgba(212,168,32,0.4),0 0 160px rgba(212,168,32,0.12);
  margin-bottom:1rem;
}
h1.hero-h1 span{color:var(--saffron-lt)}
.hero-sub{
  font-size:clamp(1.1rem,2.5vw,1.45rem);
  font-style:italic;color:var(--silver);
  margin-bottom:2.8rem;max-width:680px;
  margin-left:auto;margin-right:auto;
}
.hero-btns{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;margin-bottom:4rem}
.btn-g{
  font-family:'Cinzel',serif;font-size:0.72rem;letter-spacing:0.2em;
  text-transform:uppercase;padding:0.95rem 2.2rem;
  background:linear-gradient(135deg,var(--gold),var(--amber));
  color:var(--void);border:none;border-radius:2px;
  cursor:pointer;text-decoration:none;font-weight:700;
  box-shadow:0 4px 30px rgba(212,168,32,0.45);
  transition:transform 0.2s,box-shadow 0.2s;
}
.btn-g:hover{transform:translateY(-2px);box-shadow:0 8px 50px rgba(212,168,32,0.65)}
.btn-o{
  font-family:'Cinzel',serif;font-size:0.72rem;letter-spacing:0.2em;
