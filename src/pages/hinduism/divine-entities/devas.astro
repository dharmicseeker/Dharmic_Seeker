.mc-sub{font-family:'Cinzel',serif;font-size:0.75rem;letter-spacing:0.15em;color:var(--text-muted);margin-bottom:1rem;text-transform:uppercase}

/* ===== DEVA CATEGORY CARDS ===== */
.deva-categories{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1.8rem;margin:3rem 0}
.dcat-card{
  border:1px solid var(--border);border-radius:3px;
  background:rgba(7,8,15,0.6);
  overflow:hidden;transition:transform 0.3s,border-color 0.3s;
}
.dcat-card:hover{transform:translateY(-5px);border-color:var(--gold)}
.dcat-header{
  padding:1.6rem 1.6rem 1rem;
  display:flex;align-items:flex-start;gap:1rem;
}
.dcat-num{
  font-family:'Cinzel',serif;font-size:3rem;
  color:var(--gold);opacity:0.3;line-height:1;flex-shrink:0;
}
.dcat-title-block{}
.dcat-skt{font-family:'Noto Serif Devanagari',serif;font-size:1.4rem;color:var(--gold-pale);display:block}
.dcat-eng{font-family:'Cinzel',serif;font-size:0.68rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--saffron-lt)}
.dcat-divider{height:1px;margin:0 1.6rem;background:linear-gradient(to right,transparent,var(--border),transparent)}
.dcat-body{padding:1.2rem 1.6rem 1.6rem;font-size:0.95rem}
.dcat-tags{display:flex;flex-wrap:wrap;gap:0.35rem;margin-top:1rem}
.dtag{
  font-family:'Cinzel',serif;font-size:0.58rem;letter-spacing:0.12em;
  padding:0.22rem 0.65rem;border-radius:20px;
  border:1px solid var(--border);color:var(--text-muted);
  text-transform:uppercase;
}

/* ===== DETAIL TABLES ===== */
.deva-table{width:100%;border-collapse:collapse;margin:2rem 0;font-size:0.92rem}
.deva-table th{
  font-family:'Cinzel',serif;font-size:0.65rem;letter-spacing:0.2em;
  text-transform:uppercase;padding:0.9rem 1.2rem;
  background:rgba(212,168,32,0.08);
  border:1px solid var(--border);color:var(--gold);text-align:left;
}
.deva-table td{
  padding:0.75rem 1.2rem;
  border:1px solid rgba(212,168,32,0.12);
  color:var(--text-body);vertical-align:top;
}
.deva-table tr:nth-child(even) td{background:rgba(7,8,15,0.4)}
.deva-table tr:hover td{background:rgba(212,168,32,0.04)}
.td-name{font-family:'Noto Serif Devanagari',serif;font-size:1.05rem;color:var(--gold-pale)}
.td-eng{font-family:'Cinzel',serif;font-size:0.75rem;color:var(--gold);font-weight:600}
.td-role{color:var(--text-body)}
.td-note{font-size:0.85rem;color:var(--text-muted);font-style:italic}

/* ===== HIERARCHY ===== */
.hierarchy-tree{
  display:flex;flex-direction:column;align-items:center;
  gap:0;margin:3rem 0;
}
.hier-level{
  display:flex;flex-direction:column;align-items:center;
  width:100%;max-width:800px;
}
.hier-node{
  padding:0.8rem 2rem;border:1px solid var(--border);
  border-radius:3px;text-align:center;
  font-family:'Cinzel',serif;font-size:0.78rem;letter-spacing:0.12em;
  color:var(--gold);position:relative;
  transition:all 0.2s;cursor:default;
  background:rgba(4,4,8,0.7);
}
.hier-node:hover{border-color:var(--gold-bright);color:var(--gold-bright);background:rgba(212,168,32,0.06)}
.hier-conn{
  width:1px;height:1.5rem;
  background:linear-gradient(to bottom,var(--gold),transparent);
  opacity:0.4;
}
.hier-row{
  display:flex;gap:1rem;justify-content:center;
  flex-wrap:wrap;margin:0.2rem 0;
}
.hier-row .hier-node{flex:0 1 160px;font-size:0.7rem;padding:0.6rem 1rem}
.hier-label{
  font-family:'Cinzel',serif;font-size:0.6rem;letter-spacing:0.2em;
  text-transform:uppercase;color:var(--text-muted);margin-bottom:0.4rem;
  text-align:center;
}

/* Special tier colors */
.tier-0 .hier-node{border-color:rgba(192,64,96,0.5);color:#E080A0;background:rgba(192,64,96,0.06)}
.tier-1 .hier-node{border-color:rgba(212,168,32,0.7);color:var(--gold-bright)}
.tier-2 .hier-node{border-color:rgba(200,120,32,0.5);color:var(--saffron-lt)}
.tier-3 .hier-node{border-color:rgba(32,160,144,0.4);color:#60D0C0}
.tier-4 .hier-node{border-color:rgba(96,64,160,0.4);color:#A080D0}

/* ===== SCRIPTURE ===== */
.scripture{
  border-left:3px solid var(--gold);
  padding:1.5rem 2rem;
  background:rgba(212,168,32,0.04);
  margin:2rem 0;border-radius:0 3px 3px 0;
}
.scripture-deva{
  font-family:'Noto Serif Devanagari',serif;
  font-size:1.15rem;color:var(--gold-pale);
  line-height:1.9;margin-bottom:0.6rem;
}
.scripture-trans{font-style:italic;color:var(--text-muted);font-size:0.95rem}
.scripture-src{
  font-family:'Cinzel',serif;font-size:0.62rem;
  color:var(--saffron-lt);letter-spacing:0.2em;
  text-transform:uppercase;margin-top:0.5rem;
}

/* ===== MANVANTARA ===== */
.manv-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:1rem;margin:2.5rem 0}
.manv-card{
  border:1px solid var(--border);border-radius:3px;
  padding:1.4rem;background:rgba(7,8,15,0.5);
  transition:border-color 0.2s,transform 0.2s;
}
.manv-card:hover{border-color:var(--gold);transform:translateY(-3px)}
.manv-num{
  font-family:'Cinzel',serif;font-size:0.62rem;
  letter-spacing:0.3em;text-transform:uppercase;
  color:var(--saffron-lt);display:block;margin-bottom:0.3rem;
}
.manv-name{font-family:'Cinzel',serif;font-size:0.9rem;color:var(--gold);margin-bottom:0.3rem}
.manv-manu{font-size:0.83rem;color:var(--text-muted);font-style:italic;margin-bottom:0.5rem}
.manv-detail{font-size:0.8rem;color:var(--text-body);line-height:1.6}

/* ===== TWO COL ===== */
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start}
@media(max-width:720px){.two-col{grid-template-columns:1fr}}

/* ===== INFO CARDS ===== */
.info-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.5rem;margin:2.5rem 0}
.info-card{
  border:1px solid var(--border);border-radius:3px;
  padding:1.8rem;
  background:linear-gradient(160deg,rgba(24,27,53,0.3),rgba(4,4,8,0.85));
  transition:all 0.3s;
}
.info-card:hover{border-color:var(--gold-bright);transform:translateY(-3px)}
.ic-icon{font-size:2rem;display:block;margin-bottom:0.8rem}
.ic-title{font-family:'Cinzel',serif;font-size:0.88rem;color:var(--gold);margin-bottom:0.5rem}
.ic-text{font-size:0.9rem;color:var(--text-body);line-height:1.7}

/* ===== ACCORDION ===== */
.accordion{margin:2rem 0}
.acc-item{border:1px solid var(--border);border-radius:3px;margin-bottom:0.4rem;overflow:hidden}
.acc-h{
  padding:1.15rem 1.5rem;cursor:pointer;
  display:flex;justify-content:space-between;align-items:center;
  background:rgba(7,8,15,0.6);transition:background 0.2s;
  font-family:'Cinzel',serif;font-size:0.82rem;color:var(--gold);
  letter-spacing:0.05em;
}
.acc-h:hover{background:rgba(212,168,32,0.07)}
.acc-arr{transition:transform 0.3s;font-size:0.65rem;color:var(--text-muted)}
.acc-item.open .acc-arr{transform:rotate(180deg)}
.acc-b{
  max-height:0;overflow:hidden;
  transition:max-height 0.4s ease;
  padding:0 1.5rem;background:rgba(4,4,8,0.8);
  font-size:0.95rem;color:var(--text-body);
}
.acc-item.open .acc-b{max-height:600px;padding:1.2rem 1.5rem}

/* ===== MISCONCEPTIONS ===== */
.misconception-list{display:flex;flex-direction:column;gap:1rem;margin:2rem 0}
.myth-card{
  display:grid;grid-template-columns:auto 1fr;gap:1.5rem;
  padding:1.5rem;border-radius:3px;
  border:1px solid rgba(192,64,96,0.25);
  background:rgba(192,64,96,0.04);
}
.myth-label{
  font-family:'Cinzel',serif;font-size:0.6rem;
  letter-spacing:0.2em;text-transform:uppercase;
  padding:0.3rem 0.8rem;border-radius:20px;
  white-space:nowrap;align-self:start;margin-top:0.2rem;
}
.myth-false{background:rgba(192,64,96,0.15);color:#E080A0;border:1px solid rgba(192,64,96,0.4)}
.myth-true{background:rgba(32,160,144,0.15);color:#60D0C0;border:1px solid rgba(32,160,144,0.4)}
.myth-text{font-size:0.95rem}
.myth-text strong{color:var(--gold);font-family:'Cinzel',serif;font-size:0.82rem}

/* ===== GLOSSARY ===== */
.glossary-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:0.6rem;margin:2rem 0}
.glos-item{
  padding:0.9rem 1.2rem;border:1px solid var(--border);
  border-radius:3px;background:rgba(7,8,15,0.4);
  display:flex;flex-direction:column;gap:0.2rem;
}
.glos-skt{font-family:'Noto Serif Devanagari',serif;font-size:1.05rem;color:var(--gold-pale)}
.glos-eng{font-family:'Cinzel',serif;font-size:0.65rem;letter-spacing:0.15em;color:var(--gold);text-transform:uppercase}
.glos-def{font-size:0.83rem;color:var(--text-muted);font-style:italic}

/* ORNAMENT */
.ornament{display:flex;align-items:center;gap:1rem;margin:2rem 0}
.ornament::before,.ornament::after{content:'';flex:1;height:1px;background:linear-gradient(to right,transparent,var(--border),transparent)}
.orn-sym{color:var(--gold);font-size:1.1rem;opacity:0.6}

/* Scrollbar */
::-webkit-scrollbar{width:5px}
::-webkit-scrollbar-track{background:var(--void)}
::-webkit-scrollbar-thumb{background:var(--gold);border-radius:3px}

/* Responsive */
@media(max-width:768px){
  nav{padding:0.9rem 1.2rem}
  .nav-links{display:none}
  .wrap,.wrap-sm{padding:3.5rem 1.2rem}
  .stat-strip{flex-wrap:wrap}
  .stat-cell{min-width:45%}
}

/* Tag pills */
.pill{
  display:inline-block;font-family:'Cinzel',serif;
  font-size:0.6rem;letter-spacing:0.15em;text-transform:uppercase;
  padding:0.25rem 0.7rem;border-radius:20px;
  border:1px solid var(--border);color:var(--text-muted);
  margin:0.2rem;
}
.pill-g{border-color:rgba(212,168,32,0.4);color:var(--gold)}
.pill-s{border-color:rgba(224,80,16,0.4);color:var(--saffron-lt)}
.pill-t{border-color:rgba(32,160,144,0.4);color:#60D0C0}
.pill-v{border-color:rgba(96,64,160,0.4);color:#A080D0}

/* Callout */
.callout{
  padding:1.8rem 2rem;border-radius:3px;
  background:rgba(212,168,32,0.05);
  border:1px solid var(--border-bright);
  margin:2rem 0;
}
.callout-title{font-family:'Cinzel',serif;font-size:0.85rem;color:var(--gold-bright);margin-bottom:0.6rem}

</style>

<script is:inline>
function ta(header) {
  const item = header.parentElement;
  const open = item.classList.contains('open');

  item.parentElement
    .querySelectorAll('.acc-item.open')
    .forEach(i => i.classList.remove('open'));

  if (!open) item.classList.add('open');
}
</script>

