  .misc-correct::before { content:'✓ '; color:var(--aasi); font-weight:700; }

  /* ── REFERENCES ── */
  .ref-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(300px,1fr)); gap:12px; }
  .ref-card {
    background:var(--bg2); border:1px solid var(--border);
    border-radius:var(--r); padding:1rem 1.1rem;
  }
  .ref-badge {
    font-family:var(--mono); font-size:9px; font-weight:500;
    background:var(--bg3); color:var(--t3); padding:2px 7px;
    border-radius:3px; margin-bottom:0.5rem; display:inline-block;
  }
  .ref-title { font-family:var(--serif); font-size:14px; font-weight:600; margin-bottom:0.3rem; }
  .ref-authors { font-size:11px; color:var(--t3); margin-bottom:0.4rem; }
  .ref-body { font-size:12px; color:var(--t2); line-height:1.65; }
  .ref-doi { font-family:var(--mono); font-size:9.5px; color:var(--t3); margin-top:0.4rem; }

  /* ── CHARTS ── */
  .chart-box { position:relative; width:100%; margin-bottom:2rem; }
  .chart-note { font-size:11px; color:var(--t3); margin-top:0.5rem; font-style:italic; }

  /* ── DIVIDER ── */
  hr.section-div { border:none; border-top:1px solid var(--borderMd); margin:3rem 0; }

  /* ── PLAIN LANGUAGE BOXES ── */
  .plain-box {
    background: var(--bg3); border-radius:var(--r);
    padding:1rem 1.3rem; margin-bottom:1.5rem;
    font-size:13px; color:var(--t1); line-height:1.8;
  }
  .plain-box .pl-label {
    font-size:9px; font-weight:600; letter-spacing:0.12em;
    text-transform:uppercase; color:var(--t3); margin-bottom:0.4rem;
  }

  /* ── FORMULA BOX ── */
  .formula-box {
    font-family:var(--mono); font-size:13px;
    background:var(--bg2); border:1px solid var(--borderMd);
    border-radius:var(--r); padding:0.9rem 1.3rem;
    margin-bottom:1.5rem; color:var(--t1);
  }

  /* ── RESPONSIVE ── */
  @media(max-width:600px){
    .page { padding:2.5rem 1.2rem 6rem; }
    .hero h1 { font-size:32px; }
    .sec-title { font-size:24px; }
  }
</style>

<script>
  const dark = window.matchMedia('(prefers-color-scheme: dark)').matches;
  const gc   = dark ? 'rgba(255,255,255,0.05)' : 'rgba(0,0,0,0.05)';
  const tc   = dark ? '#706050' : '#8a8278';
  const cs   = dark ? '#e05030' : '#a8320a';
  const ci   = dark ? '#e09030' : '#b06a00';
  const ca   = dark ? '#40b070' : '#1a6840';
  const ce   = dark ? '#4080d0' : '#1a4a8a';
  const cc   = dark ? '#a060d0' : '#6a2a8a';

  /* ── CHART A ── */
  const labelsA = [
    'Rors','Kashmiri Pandit','Sindhi Brahmin','Khatri','Jat (Punjab/Haryana)',
    'Arora','Punjab Brahmin','UP Brahmin','Gujjar','Rajput',
    'Kayastha','Bhumihar','Bania','S. Indian Brahmin',
    'Yadav / Ahir','Maratha','Nair / Vellalar','Kurmi',
    'Kamma / Reddy','Mudaliar / Nadar','Meena / Mina',
    'N. Indian SC','S. Indian Dalit','Adivasi Tribes'
  ];
  const steppeA = [34,31,27,25,26,24,23,26,21,20,18,19,16,16,13,11,10,12,8,5,9,10,3,2];
  const iranA   = [38,50,50,42,40,43,43,45,41,40,41,41,44,43,38,35,37,37,33,26,34,27,19,11];
  const aasiA   = [28,19,23,33,34,33,34,29,38,40,41,40,40,41,49,54,53,51,59,69,57,63,78,87];

  new Chart(document.getElementById('chartA'), {
    type: 'bar',
    data: {
      labels: labelsA,
      datasets: [
        { label: 'Steppe', data: steppeA, backgroundColor: cs, stack: 's' },
        { label: 'Iranian Farmer', data: iranA, backgroundColor: ci, stack: 's' },
        { label: 'AASI', data: aasiA, backgroundColor: ca, stack: 's' }
      ]
    },
    options: {
      indexAxis: 'y', responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { display: true, position: 'top', labels: { color: tc, font: { size: 11 } } },
        tooltip: { callbacks: { label: c => `${c.dataset.label}: ~${c.parsed.x}%` } }
      },
      scales: {
        x: { stacked: true, max: 100, ticks: { color: tc, font: { size: 10 }, callback: v => v + '%' }, grid: { color: gc } },
        y: { stacked: true, ticks: { color: tc, font: { size: 10.5 } }, grid: { color: gc } }
      }
    }
  });

  /* ── CHART B ── */
  const labelsB = [
    'Georgian','Armenian','Iranian','Rors','Kashmiri Pandit',
    'UP Brahmin','Punjab Brahmin','Jat','S. Indian Brahmin',
    'Nair / Vellalar','Kamma / Reddy','N. Indian Dalit','S. Indian Dalit','Adivasi'
  ];
  const chgB = [62,55,50,48,46,41,38,38,34,27,24,21,13,8];
  const colsB = chgB.map(v => v >= 50 ? '#4a208a' : v >= 40 ? cc : v >= 30 ? '#9060c0' : v >= 20 ? '#b080d0' : '#caa0e0');

  new Chart(document.getElementById('chartB'), {
    type: 'bar',
    data: {
      labels: labelsB,
      datasets: [{ label: 'Total CHG ancestry', data: chgB, backgroundColor: colsB, borderRadius: 4 }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: { callbacks: { label: c => `Total CHG: ~${c.parsed.y}%` } }
      },
      scales: {
        x: { ticks: { color: tc, font: { size: 10 }, maxRotation: 40, autoSkip: false }, grid: { color: gc } },
        y: { max: 75, ticks: { color: tc, font: { size: 11 }, callback: v => v + '%' }, grid: { color: gc } }
      }
    }
  });
</script>
