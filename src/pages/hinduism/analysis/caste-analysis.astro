        </tr>
        <tr>
          <td><span class="cn">Irula / Toda / Kota</span><span class="cs">Nilgiri hills tribes</span></td>
          <td style="font-size:12px">Tamil Nadu</td>
          <td class="mono">~1–2%</td><td class="mono" style="color:var(--aasi)">~83–90%</td><td class="mono">~0%</td>
          <td style="font-size:12px;color:var(--t2)">H haplogroup dominant</td>
        </tr>
        <tr>
          <td><span class="cn">Paniyar / Koraga</span><span class="cs">Kerala / Karnataka tribal groups</span></td>
