          <td class="mono">R1a / J2</td>
        </tr>
        <tr>
          <td><span class="cn">Khatris</span><span class="cs">Punjab merchant-warrior; all 10 Sikh Gurus were Khatri</span></td>
          <td><div class="sbar"><div class="sb-s" style="width:25%"></div><div class="sb-i" style="width:42%"></div><div class="sb-a" style="width:33%"></div></div></td>
          <td class="mono">~23–26%</td><td class="mono">~40–44%</td><td class="mono">~31–35%</td>
          <td class="mono" style="color:var(--chg)">~40%</td>
          <td><span class="badge badge-vhigh">Very High</span></td>
          <td class="mono">R1a / J2</td>
        </tr>
        <tr>
          <td><span class="cn">Jats (Haryana/Punjab)</span><span class="cs">Highest Steppe among major agricultural castes</span></td>
          <td><div class="sbar"><div class="sb-s" style="width:26%"></div><div class="sb-i" style="width:40%"></div><div class="sb-a" style="width:34%"></div></div></td>
          <td class="mono">~24–27%</td><td class="mono">~38–42%</td><td class="mono">~32–38%</td>
