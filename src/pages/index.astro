    <script is:inline>
      const freqLabels = {
        daily: 'Daily wisdom — one verse, one insight every morning',
        weekly: 'Weekly digest — curated Dharmic insights every Sunday',
        monthly: 'Monthly deep dive — long-form essays on civilization and scripture'
      };

      function selectFreq(f) {
        ['daily','weekly','monthly'].forEach(id => {
          const el = document.getElementById('freq-' + id);
          if (el) {
            if (id === f) {
              el.style.background = 'var(--gold)';
              el.style.color = 'var(--deep)';
            } else {
              el.style.background = 'var(--panel)';
              el.style.color = 'var(--text-muted)';
            }
          }
        });

        const label = document.getElementById('freq-label');
        if (label) label.textContent = freqLabels[f];
      }
</script>
