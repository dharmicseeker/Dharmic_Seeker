</style>

<script>
  // COSMIC SYSTEM SPARKLES
  const sparklesContainer = document.getElementById('cosmicSparkles');
  if (sparklesContainer) {
    for (let i = 0; i < 20; i++) {
      const s = document.createElement('div');
      s.className = 'sparkle';
      const angle = Math.random() * 360;
      const radius = 60 + Math.random() * 100;
      const x = 50 + radius * Math.cos(angle * Math.PI / 180);
      const y = 50 + radius * Math.sin(angle * Math.PI / 180);
      const duration = 2 + Math.random() * 3;
      const delay = Math.random() * 4;
      s.style.cssText = `left:${x}%; top:${y}%; width:${Math.random() > 0.5 ? 2 : 1}px; height:${Math.random() > 0.5 ? 2 : 1}px; animation: sparkle-drift ${duration}s ease-in-out ${delay}s infinite;`;
      sparklesContainer.appendChild(s);
    }
  }

  // SUBTLE MOUSE PARALLAX on cosmic system
  const cosmicEl = document.getElementById('cosmicSystem');
  document.addEventListener('mousemove', (e) => {
    if (!cosmicEl) return;
    const mx = (e.clientX / window.innerWidth - 0.5) * 12;
    const my = (e.clientY / window.innerHeight - 0.5) * 8;
    cosmicEl.style.transform = `translate(${mx}px, ${my}px)`;
  });

  // SCROLL REVEAL
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) {
        setTimeout(() => entry.target.classList.add('visible'), i * 80);
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });
  reveals.forEach(el => observer.observe(el));

  // QUOTES
  let currentQuote = 0;
  const slides = document.querySelectorAll('.quote-slide');
  const dots = document.querySelectorAll('.q-dot');

  function setQuote(n: number) {
    slides[currentQuote].classList.remove('active');
    dots[currentQuote].classList.remove('active');
    currentQuote = n;
    slides[currentQuote].classList.add('active');
    dots[currentQuote].classList.add('active');
  }

  setInterval(() => {
    setQuote((currentQuote + 1) % slides.length);
  }, 5000);

  // Add keyframe via style
  const style = document.createElement('style');
  style.textContent = `
    @keyframes particle-drift {
      from { transform: translateY(0); opacity: 0; }
      10% { opacity: 0.6; }
      90% { opacity: 0.3; }
      to { transform: translateY(-110vh); opacity: 0; }
    }
  `;
  document.head.appendChild(style);
  
</script>
