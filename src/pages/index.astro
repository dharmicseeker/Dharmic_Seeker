<style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --gold: #C9933A;
    --gold-light: #E8B96A;
    --gold-pale: #F5E6C8;
    --saffron: #D4621A;
    --cream: #F9F3E8;
    --ivory: #EDE5D4;
    --deep: #0A0704;
    --dark: #120E08;
    --panel: #1A1408;
    --text-main: #EDE5D4;
    --text-muted: #9A8C78;
    --text-dim: #5C5244;
    --border: rgba(201,147,58,0.18);
    --border-strong: rgba(201,147,58,0.4);
  }

  html { scroll-behavior: smooth; font-size: 16px; }

  body {
    background: var(--deep);
    color: var(--text-main);
    font-family: 'Crimson Pro', Georgia, serif;
    font-weight: 300;
    overflow-x: hidden;
    cursor: default;
  }

  /* ─── NOISE OVERLAY ─── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9999;
    opacity: 0.6;
  }

  /* ─── HERO ─── */
  #hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
    padding: 6rem 2rem 4rem;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 30%, rgba(201,147,58,0.07) 0%, transparent 70%),
      radial-gradient(ellipse 60% 40% at 20% 80%, rgba(212,98,26,0.05) 0%, transparent 60%),
      radial-gradient(ellipse 50% 50% at 80% 70%, rgba(201,147,58,0.04) 0%, transparent 55%),
      var(--deep);
  }

  /* Mandala SVG BG */
  .mandala-bg {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 800px; height: 800px;
    opacity: 0.04;
    animation: mandala-spin 120s linear infinite;
  }
  @keyframes mandala-spin { to { transform: translate(-50%, -50%) rotate(360deg); } }

  .mandala-inner {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 500px; height: 500px;
    opacity: 0.05;
    animation: mandala-spin 80s linear infinite reverse;
  }

  /* Silhouette temple */
  .temple-silhouette {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 260px;
    background: linear-gradient(to top, rgba(10,7,4,1) 0%, transparent 100%);
    overflow: hidden;
  }
  .temple-silhouette svg {
    width: 100%;
    height: 100%;
    opacity: 0.35;
  }

  /* Floating symbols */
  .float-symbol {
    position: absolute;
    font-size: 1.4rem;
    color: var(--gold);
    opacity: 0;
    animation: float-in 8s ease-in-out infinite;
    user-select: none;
    pointer-events: none;
  }
  .float-symbol:nth-child(1) { top: 20%; left: 8%; animation-delay: 0s; }
  .float-symbol:nth-child(2) { top: 35%; right: 9%; animation-delay: 2s; }
  .float-symbol:nth-child(3) { top: 65%; left: 6%; animation-delay: 4s; }
  .float-symbol:nth-child(4) { top: 55%; right: 7%; animation-delay: 1.5s; }
  .float-symbol:nth-child(5) { top: 15%; right: 20%; animation-delay: 3s; font-size: 1rem; }
  .float-symbol:nth-child(6) { top: 75%; left: 22%; animation-delay: 5s; font-size: 1rem; }
  @keyframes float-in {
    0%, 100% { opacity: 0; transform: translateY(12px); }
    30%, 70% { opacity: 0.55; transform: translateY(0px); }
  }

  /* Particle dots */
  .particles {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .particle {
    position: absolute;
    width: 1px; height: 1px;
    background: var(--gold-light);
    border-radius: 50%;
    animation: particle-drift linear infinite;
    opacity: 0;
  }

  .hero-eyebrow {
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 0.4em;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 2rem;
    position: relative;
    z-index: 2;
    animation: fade-up 1s ease forwards;
    animation-delay: 0.3s;
    opacity: 0;
  }
  .hero-eyebrow::before, .hero-eyebrow::after {
    content: '—';
    margin: 0 1rem;
    opacity: 0.5;
  }

  .hero-headline {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3.5rem, 8vw, 7rem);
    font-weight: 300;
    line-height: 1.05;
    color: var(--cream);
    letter-spacing: -0.01em;
    max-width: 900px;
    margin-bottom: 1.5rem;
    position: relative;
    z-index: 2;
    animation: fade-up 1s ease forwards;
    animation-delay: 0.6s;
    opacity: 0;
  }
  .hero-headline em {
    font-style: italic;
    color: var(--gold-light);
  }

  .hero-sub {
    font-size: 1.25rem;
    color: var(--text-muted);
    max-width: 560px;
    line-height: 1.7;
    margin-bottom: 3rem;
    position: relative;
    z-index: 2;
    animation: fade-up 1s ease forwards;
    animation-delay: 0.9s;
    opacity: 0;
  }

  .hero-actions {
    display: flex;
    gap: 1.2rem;
    flex-wrap: wrap;
    justify-content: center;
    position: relative;
    z-index: 2;
    animation: fade-up 1s ease forwards;
    animation-delay: 1.2s;
    opacity: 0;
  }

  .btn-primary {
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--deep);
    background: var(--gold);
    border: 1px solid var(--gold);
    padding: 1rem 2.5rem;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.3s;
    display: inline-block;
  }
  .btn-primary:hover { background: var(--gold-light); border-color: var(--gold-light); }

  .btn-secondary {
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--gold-light);
    background: transparent;
    border: 1px solid var(--border-strong);
    padding: 1rem 2.5rem;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.3s;
    display: inline-block;
  }
  .btn-secondary:hover { border-color: var(--gold); color: var(--gold); }

  .hero-scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    opacity: 0;
    animation: fade-up 1s ease forwards;
    animation-delay: 2s;
  }
  .scroll-line {
    width: 1px; height: 50px;
    background: linear-gradient(to bottom, transparent, var(--gold));
    animation: scroll-line 2s ease-in-out infinite;
  }
  @keyframes scroll-line {
    0%, 100% { transform: scaleY(0); transform-origin: top; }
    50% { transform: scaleY(1); transform-origin: top; }
  }
  .scroll-label {
    font-family: 'Cinzel', serif;
    font-size: 9px;
    letter-spacing: 0.3em;
    color: var(--text-dim);
    text-transform: uppercase;
  }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ─── DIVIDER ─── */
  .divider {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin: 0 auto 5rem;
    max-width: 200px;
  }
  .divider-line { flex: 1; height: 1px; background: var(--border); }
  .divider-glyph {
    font-size: 1rem;
    color: var(--gold);
    opacity: 0.7;
  }

  /* ─── SECTION BASE ─── */
  section {
    position: relative;
    padding: 7rem 4rem;
    max-width: 1400px;
    margin: 0 auto;
  }
  section.full-width { max-width: none; }

  .section-eyebrow {
    font-family: 'Cinzel', serif;
    font-size: 9px;
    letter-spacing: 0.45em;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 1.2rem;
    display: block;
  }

  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 300;
    color: var(--cream);
    line-height: 1.15;
    margin-bottom: 1.5rem;
  }
  .section-title em { font-style: italic; color: var(--gold-light); }

  .section-lead {
    font-size: 1.1rem;
    color: var(--text-muted);
    line-height: 1.8;
    max-width: 600px;
  }

  /* ─── ABOUT DHARMA ─── */
  #about {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
    padding-top: 8rem;
  }

  .about-visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ─── DHARMIC COSMIC SYSTEM (3D ATOMIC) ─── */
  .cosmic-system {
    position: relative;
    width: 380px; height: 380px;
    perspective: 900px;
    transform-style: preserve-3d;
  }

  .cosmic-center {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 88px; height: 88px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, rgba(255,255,255,0.15) 0%, rgba(201,147,58,0.12) 40%, rgba(201,147,58,0.04) 70%, transparent 100%);
    border: 1.5px solid rgba(255,255,255,0.55);
    display: flex; align-items: center; justify-content: center;
    z-index: 20;
    box-shadow:
      0 0 0 8px rgba(201,147,58,0.06),
      0 0 30px rgba(255,255,255,0.12),
      0 0 60px rgba(201,147,58,0.18),
      inset 0 1px 0 rgba(255,255,255,0.2);
    animation: om-pulse 4s ease-in-out infinite;
  }
  .om-glyph {
    font-size: 2.6rem;
    color: #ffffff;
    text-shadow: 0 0 14px rgba(255,255,255,0.9), 0 0 30px rgba(201,147,58,0.5);
    line-height: 1;
    user-select: none;
    filter: drop-shadow(0 0 6px rgba(255,255,255,0.6));
  }
  @keyframes om-pulse {
    0%, 100% {
      box-shadow: 0 0 0 8px rgba(201,147,58,0.06), 0 0 30px rgba(255,255,255,0.12), 0 0 60px rgba(201,147,58,0.18), inset 0 1px 0 rgba(255,255,255,0.2);
    }
    50% {
      box-shadow: 0 0 0 14px rgba(201,147,58,0.09), 0 0 50px rgba(255,255,255,0.2), 0 0 100px rgba(201,147,58,0.28), inset 0 1px 0 rgba(255,255,255,0.3);
    }
  }

  /* 3D Orbital rings — four planes at different angles like electron shells */
  .orbital-plane {
    position: absolute;
    top: 50%; left: 50%;
    border-radius: 50%;
    border: 1px solid rgba(201,147,58,0.22);
    transform-style: preserve-3d;
    transform-origin: center center;
  }
  /* Ring 1 — Hinduism orbit — front tilted plane */
  .orbital-plane-1 {
    width: 180px; height: 180px;
    margin: -90px 0 0 -90px;
    border-color: rgba(201,147,58,0.30);
    animation: ring3d-1 20s linear infinite;
    box-shadow: 0 0 8px rgba(201,147,58,0.08);
  }
  /* Ring 2 — Buddhism orbit — different tilt */
  .orbital-plane-2 {
    width: 240px; height: 100px;
    margin: -50px 0 0 -120px;
    border-color: rgba(201,147,58,0.20);
    border-radius: 50%;
    animation: ring3d-2 26s linear infinite reverse;
  }
  /* Ring 3 — Sikhism orbit */
  .orbital-plane-3 {
    width: 290px; height: 120px;
    margin: -60px 0 0 -145px;
    border-color: rgba(201,147,58,0.15);
    border-radius: 50%;
    animation: ring3d-3 34s linear infinite;
  }
  /* Ring 4 — Jainism orbit */
  .orbital-plane-4 {
    width: 210px; height: 210px;
    margin: -105px 0 0 -105px;
    border-color: rgba(201,147,58,0.12);
    animation: ring3d-4 28s linear infinite reverse;
  }

  @keyframes ring3d-1 {
    from { transform: rotateX(72deg) rotateZ(0deg); }
    to   { transform: rotateX(72deg) rotateZ(360deg); }
  }
  @keyframes ring3d-2 {
    from { transform: rotateX(20deg) rotateY(60deg) rotateZ(0deg); }
    to   { transform: rotateX(20deg) rotateY(60deg) rotateZ(360deg); }
  }
  @keyframes ring3d-3 {
    from { transform: rotateX(55deg) rotateY(-30deg) rotateZ(0deg); }
    to   { transform: rotateX(55deg) rotateY(-30deg) rotateZ(360deg); }
  }
  @keyframes ring3d-4 {
    from { transform: rotateX(80deg) rotateY(45deg) rotateZ(0deg); }
    to   { transform: rotateX(80deg) rotateY(45deg) rotateZ(360deg); }
  }

  /* Orbiting symbol nodes */
  .dharmic-symbol {
    position: absolute;
    top: 50%; left: 50%;
    display: flex; align-items: center; justify-content: center;
    width: 46px; height: 46px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 30%, rgba(40,30,10,0.98), rgba(18,14,8,0.98));
    border: 1px solid rgba(201,147,58,0.45);
    font-size: 1.25rem;
    color: #ffffff;
    text-shadow: 0 0 8px rgba(255,255,255,0.6);
    box-shadow:
      0 0 14px rgba(201,147,58,0.25),
      0 2px 8px rgba(0,0,0,0.6),
      inset 0 1px 0 rgba(255,255,255,0.08);
    z-index: 5;
  }
  .sym-hinduism {
    animation: orbit-sym-1 20s linear infinite;
    --r: 90px;
  }
  .sym-buddhism {
    animation: orbit-sym-2 26s linear infinite;
    --r: 115px;
    animation-delay: -8s;
  }
  .sym-sikhism {
    animation: orbit-sym-3 34s linear infinite;
    --r: 140px;
    animation-delay: -14s;
  }
  .sym-jainism {
    animation: orbit-sym-4 28s linear infinite;
    --r: 102px;
    animation-delay: -20s;
  }
  @keyframes orbit-sym-1 {
    0%   { transform: translate(-50%,-50%) rotateX(72deg) rotate(0deg)   translateX(90px) rotateX(-72deg) rotate(0deg); }
    100% { transform: translate(-50%,-50%) rotateX(72deg) rotate(360deg) translateX(90px) rotateX(-72deg) rotate(-360deg); }
  }
  @keyframes orbit-sym-2 {
    0%   { transform: translate(-50%,-50%) rotateX(20deg) rotateY(60deg) rotate(0deg)   translateX(115px) rotateY(-60deg) rotateX(-20deg) rotate(0deg); }
    100% { transform: translate(-50%,-50%) rotateX(20deg) rotateY(60deg) rotate(-360deg) translateX(115px) rotateY(-60deg) rotateX(-20deg) rotate(360deg); }
  }
  @keyframes orbit-sym-3 {
    0%   { transform: translate(-50%,-50%) rotateX(55deg) rotateY(-30deg) rotate(0deg)   translateX(140px) rotateY(30deg) rotateX(-55deg) rotate(0deg); }
    100% { transform: translate(-50%,-50%) rotateX(55deg) rotateY(-30deg) rotate(360deg) translateX(140px) rotateY(30deg) rotateX(-55deg) rotate(-360deg); }
  }
  @keyframes orbit-sym-4 {
    0%   { transform: translate(-50%,-50%) rotateX(80deg) rotateY(45deg) rotate(0deg)   translateX(102px) rotateY(-45deg) rotateX(-80deg) rotate(0deg); }
    100% { transform: translate(-50%,-50%) rotateX(80deg) rotateY(45deg) rotate(-360deg) translateX(102px) rotateY(-45deg) rotateX(-80deg) rotate(360deg); }
  }

  /* Particle sparkles around cosmic system */
  .cosmic-sparkles {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .sparkle {
    position: absolute;
    width: 2px; height: 2px;
    border-radius: 50%;
    background: var(--gold-light);
    animation: sparkle-drift linear infinite;
    opacity: 0;
  }
  @keyframes sparkle-drift {
    0%   { opacity: 0; transform: scale(0); }
    20%  { opacity: 0.7; transform: scale(1); }
    80%  { opacity: 0.3; }
    100% { opacity: 0; transform: scale(0) translateY(-30px); }
  }


  .dharma-pillars {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    margin-top: 3rem;
    border: 1px solid var(--border);
  }
  .pillar {
    padding: 1.5rem;
    border: 1px solid var(--border);
    background: rgba(201,147,58,0.02);
    transition: background 0.3s;
  }
  .pillar:hover { background: rgba(201,147,58,0.05); }
  .pillar-symbol { font-size: 1.5rem; margin-bottom: 0.5rem; display: block; }
  .pillar-name {
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--gold);
    margin-bottom: 0.4rem;
  }
  .pillar-desc { font-size: 0.9rem; color: var(--text-dim); line-height: 1.6; }

  /* ─── RELIGIONS ─── */
  #religions {
    padding-top: 8rem;
    padding-bottom: 8rem;
  }
  .religion-header {
    text-align: center;
    margin-bottom: 5rem;
  }
  .religion-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--border);
  }

  .religion-card {
    background: var(--dark);
    padding: 2.5rem 2rem;
    position: relative;
    overflow: hidden;
    cursor: pointer;
    transition: all 0.4s ease;
  }
  .religion-card::before {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
    background: var(--accent-color, var(--gold));
    transform: scaleX(0);
    transition: transform 0.4s ease;
    transform-origin: left;
  }
  .religion-card:hover::before { transform: scaleX(1); }
  .religion-card:hover { background: rgba(26,20,8,0.9); transform: translateY(-4px); }

  .religion-card:nth-child(1) { --accent-color: #FF8C42; }
  .religion-card:nth-child(2) { --accent-color: #4FA8D4; }
  .religion-card:nth-child(3) { --accent-color: #8B6FD4; }
  .religion-card:nth-child(4) { --accent-color: #5BA06A; }

  .card-symbol {
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
    display: block;
    opacity: 0.9;
  }
  .card-tradition {
    font-family: 'Cinzel', serif;
    font-size: 9px;
    letter-spacing: 0.35em;
    color: var(--text-dim);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }
  .card-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.6rem;
    font-weight: 400;
    color: var(--cream);
    line-height: 1.2;
    margin-bottom: 1rem;
  }
  .card-tagline {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }
  .card-meta {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding-top: 1.2rem;
    border-top: 1px solid var(--border);
    margin-bottom: 1.5rem;
  }
  .meta-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
  }
  .meta-label { color: var(--text-dim); font-family: 'Cinzel', serif; font-size: 9px; letter-spacing: 0.1em; }
  .meta-val { color: var(--text-muted); }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.5rem;
  }
  .tag {
    font-family: 'Cinzel', serif;
    font-size: 8px;
    letter-spacing: 0.15em;
    padding: 0.25rem 0.7rem;
    border: 1px solid var(--border);
    color: var(--text-dim);
    text-transform: uppercase;
  }

  .card-cta {
    font-family: 'Cinzel', serif;
    font-size: 9px;
    letter-spacing: 0.25em;
    color: var(--accent-color, var(--gold));
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: gap 0.3s;
  }
  .card-cta:hover { gap: 0.9rem; }
  .card-cta::after { content: '→'; }

  /* ─── TIMELINE ─── */
  #timeline {
    padding: 8rem 4rem;
    position: relative;
    overflow: hidden;
  }
  .timeline-header { text-align: center; margin-bottom: 5rem; }

  .timeline-track {
    position: relative;
    padding: 2rem 0;
  }
  .timeline-axis {
    position: absolute;
    top: 50%;
    left: 0; right: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--border-strong) 10%, var(--border-strong) 90%, transparent);
  }
  .timeline-events {
    display: flex;
    gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
    padding: 4rem 2rem;
    position: relative;
  }
  .timeline-events::-webkit-scrollbar { display: none; }

  .t-event {
    flex: 0 0 220px;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .t-event:nth-child(even) .t-card { margin-top: 5rem; }
  .t-event:nth-child(even) .t-dot { order: -1; }
  .t-event:nth-child(odd) .t-card { margin-bottom: 5rem; order: -1; }

  .t-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    background: var(--gold);
    border: 2px solid var(--deep);
    position: relative;
    z-index: 2;
    flex-shrink: 0;
    box-shadow: 0 0 12px rgba(201,147,58,0.4);
  }
  .t-line {
    width: 1px; height: 3rem;
    background: var(--border-strong);
  }
  .t-card {
    background: var(--panel);
    border: 1px solid var(--border);
    padding: 1.2rem 1.5rem;
    width: 180px;
    text-align: center;
    transition: border-color 0.3s;
  }
  .t-card:hover { border-color: var(--gold); }
  .t-year {
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 0.15em;
    color: var(--gold);
    margin-bottom: 0.3rem;
  }
  .t-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.95rem;
    color: var(--cream);
    line-height: 1.3;
  }
  .t-desc { font-size: 0.75rem; color: var(--text-dim); margin-top: 0.3rem; }

  /* ─── WISDOM QUOTES ─── */
  #wisdom {
    padding: 8rem 4rem;
    background: linear-gradient(to bottom, var(--deep), var(--panel), var(--deep));
    max-width: none;
    text-align: center;
  }
  .wisdom-header { margin-bottom: 4rem; }

  .quotes-carousel {
    position: relative;
    max-width: 800px;
    margin: 0 auto;
    min-height: 200px;
  }
