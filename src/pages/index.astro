---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Dharmic Seeker" fullWidth={true}>


<!-- HERO -->
<div id="hero">
  <div class="hero-bg"></div>

  <!-- Mandala BGs -->
  <svg class="mandala-bg" viewBox="0 0 500 500" fill="none" xmlns="http://www.w3.org/2000/svg">
    <g stroke="#C9933A" stroke-width="0.5">
      <circle cx="250" cy="250" r="240"/><circle cx="250" cy="250" r="200"/><circle cx="250" cy="250" r="160"/>
      <circle cx="250" cy="250" r="120"/><circle cx="250" cy="250" r="80"/><circle cx="250" cy="250" r="40"/>
      <line x1="10" y1="250" x2="490" y2="250"/><line x1="250" y1="10" x2="250" y2="490"/>
      <line x1="74" y1="74" x2="426" y2="426"/><line x1="426" y1="74" x2="74" y2="426"/>
      <line x1="10" y1="143" x2="490" y2="357"/><line x1="10" y1="357" x2="490" y2="143"/>
      <line x1="143" y1="10" x2="357" y2="490"/><line x1="357" y1="10" x2="143" y2="490"/>
      <polygon points="250,30 470,390 30,390" fill="none"/>
      <polygon points="250,470 30,110 470,110" fill="none"/>
    </g>
  </svg>

  <svg class="mandala-inner" viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg">
    <g stroke="#C9933A" stroke-width="0.8">
      <circle cx="200" cy="200" r="180"/><circle cx="200" cy="200" r="140"/><circle cx="200" cy="200" r="100"/><circle cx="200" cy="200" r="60"/>
      <line x1="20" y1="200" x2="380" y2="200"/><line x1="200" y1="20" x2="200" y2="380"/>
      <line x1="73" y1="73" x2="327" y2="327"/><line x1="327" y1="73" x2="73" y2="327"/>
    </g>
  </svg>

  <!-- Floating Symbols -->
  <span class="float-symbol">ॐ</span>
  <span class="float-symbol">☸</span>
  <span class="float-symbol">🪷</span>
  <span class="float-symbol">🔱</span>
  <span class="float-symbol">☯</span>
  <span class="float-symbol">卍</span>

  <!-- Temple Silhouette -->
  <div class="temple-silhouette">
    <svg viewBox="0 0 1440 260" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path fill="rgba(201,147,58,0.5)"
        d="
        M0 260 L0 200
        L60 200 L60 180 L80 160 L80 140 L90 120 L90 100 L100 80 L100 100 L110 100 L110 60 L120 40 L125 20 L130 40 L135 60 L140 60 L140 100 L150 80 L150 100 L160 120 L160 140 L170 160 L170 180 L190 200
        L220 200 L220 220
        L260 220 L260 200
        L300 200 L300 180 L310 160 L315 140 L320 120 L320 100 L325 80 L325 60 L330 40 L332 20 L334 40 L335 60 L335 80 L340 100 L340 120 L345 140 L350 160 L360 180 L360 200
        L420 200 L420 220
        L460 220 L460 200
        L520 200 L520 160 L540 120 L550 80 L555 40 L560 10 L565 40 L570 80 L580 120 L600 160 L600 200
        L640 200 L640 220
        L700 220 L700 200
        L760 200 L760 180 L770 160 L775 130 L780 100 L785 70 L790 40 L793 15 L796 40 L800 70 L805 100 L810 130 L815 160 L825 180 L825 200
        L900 200 L900 220
        L940 220 L940 200
        L1000 200 L1000 160 L1010 120 L1020 80 L1025 40 L1030 10 L1035 40 L1040 80 L1050 120 L1060 160 L1060 200
        L1120 200
        L1160 200 L1160 180 L1170 160 L1175 140 L1180 120 L1180 100 L1185 80 L1185 60 L1190 40 L1192 20 L1194 40 L1195 60 L1195 80 L1200 100 L1200 120 L1205 140 L1210 160 L1220 180 L1220 200
        L1280 200 L1280 220
        L1320 220 L1320 200
        L1380 200 L1380 180 L1390 160 L1395 140 L1400 120 L1400 100 L1405 80 L1410 60 L1415 40 L1417 20 L1419 40 L1420 60 L1425 80 L1425 100 L1430 120 L1430 140 L1435 160 L1440 180 L1440 260
        Z"/>
    </svg>
  </div>

  <span class="hero-eyebrow">Est. 2026 &nbsp;·&nbsp; Bharat Digital Heritage</span>

  <h1 class="hero-headline">
    Seek the <em>Eternal</em><br>Dharma
  </h1>

  <p class="hero-sub">
    A living library of Sanatan Dharma, Buddhism, Jainism & Sikhism. Ancient wisdom, rendered for the age of exploration.
  </p>

  <div class="hero-actions">
    <a href="#religions" class="btn-primary">Explore Traditions</a>
    <a href="#about" class="btn-secondary">What is Dharma?</a>
  </div>

  <div class="hero-scroll-hint">
    <div class="scroll-line"></div>
    <span class="scroll-label">Scroll</span>
  </div>
</div>

<!-- ABOUT DHARMA -->
<section id="about">
  <div class="about-visual reveal">
    <div class="cosmic-system" id="cosmicSystem">
      <!-- 3D Orbital planes (electron-shell rings at different angles) -->
      <div class="orbital-plane orbital-plane-1"></div>
      <div class="orbital-plane orbital-plane-2"></div>
      <div class="orbital-plane orbital-plane-3"></div>
      <div class="orbital-plane orbital-plane-4"></div>

      <!-- Center Om — pure white -->
      <div class="cosmic-center">
        <span class="om-glyph">ॐ</span>
      </div>

      <!-- Hinduism: Swastika (traditional sacred form) -->
      <div class="dharmic-symbol sym-hinduism" title="Hinduism — Swastik">
        <svg width="22" height="22" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M50 50 L50 10 L90 10" stroke="#F5E6C8" stroke-width="12" stroke-linecap="square"/>
          <path d="M50 50 L50 90 L10 90" stroke="#F5E6C8" stroke-width="12" stroke-linecap="square"/>
          <path d="M50 50 L10 50 L10 10" stroke="#F5E6C8" stroke-width="12" stroke-linecap="square"/>
          <path d="M50 50 L90 50 L90 90" stroke="#F5E6C8" stroke-width="12" stroke-linecap="square"/>
        </svg>
      </div>

      <!-- Buddhism: Dharma Chakra -->
      <div class="dharmic-symbol sym-buddhism" title="Buddhism — Dharma Chakra">
        <span style="font-size:1.4rem;">☸</span>
      </div>

      <!-- Sikhism: Khanda -->
      <div class="dharmic-symbol sym-sikhism" title="Sikhism — Khanda">
        <svg width="20" height="22" viewBox="0 0 80 90" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Double-edged sword (central blade) -->
          <path d="M40 5 L36 70 L40 75 L44 70 Z" fill="#F5E6C8"/>
          <!-- Chakkar (circle) -->
          <circle cx="40" cy="45" r="22" stroke="#F5E6C8" stroke-width="5" fill="none"/>
          <!-- Left kirpan -->
          <path d="M18 10 Q8 45 18 75" stroke="#F5E6C8" stroke-width="4" fill="none" stroke-linecap="round"/>
          <!-- Right kirpan -->
          <path d="M62 10 Q72 45 62 75" stroke="#F5E6C8" stroke-width="4" fill="none" stroke-linecap="round"/>
        </svg>
      </div>

      <!-- Jainism: Ahimsa hand -->
      <div class="dharmic-symbol sym-jainism" title="Jainism — Ahimsa">
        <svg width="20" height="22" viewBox="0 0 80 90" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Palm outline -->
          <path d="M20 80 Q10 60 12 40 Q14 28 20 22 Q24 18 28 22 L28 15 Q28 8 34 8 Q40 8 40 15 L40 12 Q40 5 46 5 Q52 5 52 12 L52 15 Q52 8 58 8 Q64 8 64 15 L64 50 Q66 60 60 70 L55 80 Z" stroke="#F5E6C8" stroke-width="4" fill="none" stroke-linejoin="round"/>
          <!-- Ahimsa dot (circle on palm) -->
          <circle cx="42" cy="48" r="9" stroke="#F5E6C8" stroke-width="4" fill="none"/>
        </svg>
      </div>

      <!-- Sparkle particles -->
      <div class="cosmic-sparkles" id="cosmicSparkles"></div>
    </div>
  </div>
  <div class="about-content reveal">
    <span class="section-eyebrow">The Foundation</span>
    <h2 class="section-title">What is <em>Dharma</em>?</h2>
    <p class="section-lead">
      Dharma is not merely a religion — it is the eternal order underlying all of existence. Rooted in the Sanskrit root <em>dhṛ</em> (to hold, to sustain), it represents the cosmic law that keeps the universe in balance.
    </p>
    <p class="section-lead" style="margin-top:1rem; font-style:italic; border-left: 2px solid var(--gold); padding-left:1.2rem;">
      "Dharma is that which supports, upholds, and nourishes the cosmos, society, and the individual simultaneously."
    </p>
    <div class="dharma-pillars">
      <div class="pillar">
        <span class="pillar-symbol">⚖️</span>
        <div class="pillar-name">Ṛta</div>
        <div class="pillar-desc">Cosmic order and natural law governing all existence</div>
      </div>
      <div class="pillar">
        <span class="pillar-symbol">🔥</span>
        <div class="pillar-name">Satya</div>
        <div class="pillar-desc">Truth as the ultimate foundation of righteous action</div>
      </div>
      <div class="pillar">
        <span class="pillar-symbol">🌸</span>
        <div class="pillar-name">Ahiṃsā</div>
        <div class="pillar-desc">Non-violence as the highest moral and spiritual principle</div>
      </div>
      <div class="pillar">
        <span class="pillar-symbol">♾️</span>
        <div class="pillar-name">Moksha</div>
        <div class="pillar-desc">Liberation from the cycle of birth and rebirth</div>
      </div>
    </div>
  </div>
</section>

<!-- RELIGIONS -->
<section id="religions" class="full-width" style="max-width:none; padding:8rem 4rem;">
  <div class="religion-header reveal">
    <span class="section-eyebrow">Four Traditions</span>
    <h2 class="section-title">The Dharmic Cosmos</h2>
    <p class="section-lead" style="margin:0 auto; text-align:center;">
      Four distinct yet profoundly interconnected rivers of wisdom — each flowing from the spiritual heartland of Bharat.
    </p>
  </div>
  <div class="religion-grid reveal" style="max-width:1400px; margin:0 auto;">

    <div class="religion-card" onclick="window.location='/hinduism/'">
      <span class="card-symbol">🕉</span>
      <div class="card-tradition">Sanatan Dharma</div>
      <div class="card-name">Hinduism</div>
      <div class="card-tagline">The world's oldest living spiritual tradition — a vast, plural, ever-evolving cosmic philosophy.</div>
      <div class="card-meta">
        <div class="meta-row"><span class="meta-label">Origin</span><span class="meta-val">c. 3000 BCE+</span></div>
        <div class="meta-row"><span class="meta-label">Scripture</span><span class="meta-val">Vedas, Upanishads, Gita</span></div>
        <div class="meta-row"><span class="meta-label">Symbol</span><span class="meta-val">Om · Lotus · Swastika</span></div>
        <div class="meta-row"><span class="meta-label">Sacred Sites</span><span class="meta-val">Varanasi, Tirupati, Dwarka</span></div>
      </div>
      <div class="card-tags">
        <span class="tag">Vedanta</span>
        <span class="tag">Yoga</span>
        <span class="tag">Advaita</span>
        <span class="tag">Bhakti</span>
      </div>
      <a href="#" class="card-cta">Explore Tradition</a>
    </div>

    <div class="religion-card" onclick="window.location='/buddhism/'">
      <span class="card-symbol">☸</span>
      <div class="card-tradition">The Enlightened Path</div>
      <div class="card-name">Buddhism</div>
      <div class="card-tagline">Born from the Bodhi tree — a philosophy of liberation through compassion, wisdom, and mindful awareness.</div>
      <div class="card-meta">
        <div class="meta-row"><span class="meta-label">Founder</span><span class="meta-val">Siddhartha Gautama</span></div>
        <div class="meta-row"><span class="meta-label">Origin</span><span class="meta-val">c. 563 BCE, Lumbini</span></div>
        <div class="meta-row"><span class="meta-label">Scripture</span><span class="meta-val">Tripitaka, Dhammapada</span></div>
        <div class="meta-row"><span class="meta-label">Sacred Sites</span><span class="meta-val">Bodh Gaya, Sarnath</span></div>
      </div>
      <div class="card-tags">
        <span class="tag">Nirvana</span>
        <span class="tag">Theravada</span>
        <span class="tag">Zen</span>
        <span class="tag">Mahayana</span>
      </div>
      <a href="#" class="card-cta">Explore Tradition</a>
    </div>

    <div class="religion-card" onclick="window.location='/jainism/'">
      <span class="card-symbol">🔱</span>
      <div class="card-tradition">The Path of Liberation</div>
      <div class="card-name">Jainism</div>
      <div class="card-tagline">One of humanity's most ancient philosophies — non-violence, non-possession, and truth as cosmic law.</div>
      <div class="card-meta">
        <div class="meta-row"><span class="meta-label">Reformer</span><span class="meta-val">Mahavira (599 BCE)</span></div>
        <div class="meta-row"><span class="meta-label">Tirthankaras</span><span class="meta-val">24 Spiritual Fords</span></div>
        <div class="meta-row"><span class="meta-label">Scripture</span><span class="meta-val">Agamas, Tattvartha Sutra</span></div>
        <div class="meta-row"><span class="meta-label">Sacred Sites</span><span class="meta-val">Palitana, Shravanabelagola</span></div>
      </div>
      <div class="card-tags">
        <span class="tag">Ahimsa</span>
        <span class="tag">Anekantavada</span>
        <span class="tag">Aparigraha</span>
      </div>
      <a href="#" class="card-cta">Explore Tradition</a>
    </div>

    <div class="religion-card" onclick="window.location='/sikhism/'">
      <span class="card-symbol">☬</span>
      <div class="card-tradition">The Sikh Path</div>
      <div class="card-name">Sikhism</div>
      <div class="card-tagline">Ik Onkar — One Universal Creator. A living tradition of courage, equality, and devotion to the Divine Name.</div>
      <div class="card-meta">
        <div class="meta-row"><span class="meta-label">Founder</span><span class="meta-val">Guru Nanak Dev Ji</span></div>
        <div class="meta-row"><span class="meta-label">Origin</span><span class="meta-val">c. 1469 CE, Punjab</span></div>
        <div class="meta-row"><span class="meta-label">Scripture</span><span class="meta-val">Guru Granth Sahib</span></div>
        <div class="meta-row"><span class="meta-label">Sacred Sites</span><span class="meta-val">Harmandir Sahib, Anandpur</span></div>
      </div>
      <div class="card-tags">
        <span class="tag">Waheguru</span>
        <span class="tag">Seva</span>
        <span class="tag">Langar</span>
        <span class="tag">Khalsa</span>
      </div>
      <a href="#" class="card-cta">Explore Tradition</a>
    </div>

  </div>
</section>

<!-- TIMELINE -->
<section id="timeline" class="full-width" style="max-width:none; padding:8rem 4rem; background: var(--panel);">
  <div class="timeline-header reveal">
    <span class="section-eyebrow">Through the Ages</span>
    <h2 class="section-title" style="text-align:center;">The Civilizational <em>Continuum</em></h2>
    <p class="section-lead" style="margin:0 auto; text-align:center;">
      5,000 years of unbroken spiritual evolution — from the Vedic Rishis to the Sikh Gurus.
    </p>
  </div>
  <div class="timeline-track reveal">
    <div class="timeline-axis"></div>
    <div class="timeline-events">
      <div class="t-event">
        <div class="t-card"><div class="t-year">c. 5000+ BCE</div><div class="t-name">Vedic Civilization</div><div class="t-desc">Rig Veda composed by the Rishis; Saraswati valley culture blooms in Satya Yuga</div></div>
        <div class="t-line"></div>
        <div class="t-dot"></div>
      </div>
      <div class="t-event">
        <div class="t-dot"></div>
        <div class="t-line"></div>
        <div class="t-card"><div class="t-year">c. 5000 BCE</div><div class="t-name">Ramayana Era</div><div class="t-desc">Treta Yuga — Sri Rama's Dharmic journey; Valmiki's Ramayana composed</div></div>
      </div>
      <div class="t-event">
        <div class="t-card"><div class="t-year">c. 3102 BCE</div><div class="t-name">Mahabharata Era</div><div class="t-desc">Dvapara Yuga ends; Bhagavad Gita revealed at Kurukshetra; start of Kali Yuga</div></div>
        <div class="t-line"></div>
        <div class="t-dot"></div>
      </div>
      <div class="t-event">
        <div class="t-dot"></div>
        <div class="t-line"></div>
        <div class="t-card"><div class="t-year">c. 1500 BCE</div><div class="t-name">Upanishadic Age</div><div class="t-desc">Brahman, Atman, Moksha — the Aranyakas and 108 Upanishads emerge</div></div>
      </div>
      <div class="t-event">
        <div class="t-card"><div class="t-year">c. 877 BCE</div><div class="t-name">Parshvanatha</div><div class="t-desc">23rd Tirthankara — forerunner of Jain tradition revived before Mahavira</div></div>
        <div class="t-line"></div>
        <div class="t-dot"></div>
      </div>
      <div class="t-event">
        <div class="t-dot"></div>
        <div class="t-line"></div>
        <div class="t-card"><div class="t-year">c. 599 BCE</div><div class="t-name">Mahavira</div><div class="t-desc">24th Tirthankara teaches the path of Ahimsa and liberation; Jainism formalized</div></div>
      </div>
      <div class="t-event">
        <div class="t-card"><div class="t-year">c. 563 BCE</div><div class="t-name">Siddhartha Gautama</div><div class="t-desc">Birth of the Buddha at Lumbini; the Eightfold Path and Middle Way revealed</div></div>
        <div class="t-line"></div>
        <div class="t-dot"></div>
      </div>
      <div class="t-event">
        <div class="t-dot"></div>
        <div class="t-line"></div>
        <div class="t-card"><div class="t-year">c. 268 BCE</div><div class="t-name">Ashoka's Dharma</div><div class="t-desc">Mauryan emperor Ashoka spreads Dhamma and the Dharma Chakra across Asia</div></div>
      </div>
      <div class="t-event">
        <div class="t-card"><div class="t-year">788 CE</div><div class="t-name">Adi Shankaracharya</div><div class="t-desc">Advaita Vedanta renaissance; four cardinal mathas established across Bharat</div></div>
        <div class="t-line"></div>
        <div class="t-dot"></div>
      </div>
      <div class="t-event">
        <div class="t-dot"></div>
        <div class="t-line"></div>
        <div class="t-card"><div class="t-year">1469 CE</div><div class="t-name">Guru Nanak Dev Ji</div><div class="t-desc">Sikhism founded; Ik Onkar proclaimed in the Punjab</div></div>
      </div>
      <div class="t-event">
        <div class="t-dot"></div>
        <div class="t-line"></div>
        <div class="t-card"><div class="t-year">1708 CE</div><div class="t-name">Guru Granth Sahib</div><div class="t-desc">The eternal living Guru installed as perpetual scripture by Guru Gobind Singh</div></div>
      </div>
    </div>
  </div>
</section>

<!-- WISDOM QUOTES -->
<section id="wisdom" class="full-width">
  <div class="wisdom-header reveal">
    <span class="section-eyebrow">Featured Wisdom</span>
    <h2 class="section-title" style="text-align:center;">Voices of the <em>Eternal</em></h2>
  </div>
  <div class="quotes-carousel reveal">
    <div class="quote-slide active">
      <p class="quote-text">"You have the right to perform your prescribed duties, but you are not entitled to the fruits of your actions."</p>
      <div class="quote-source">Bhagavad Gita · 2.47</div>
      <div class="quote-tradition">Sanatan Dharma — Lord Krishna to Arjuna</div>
    </div>
    <div class="quote-slide">
      <p class="quote-text">"Peace comes from within. Do not seek it without. The mind is everything. What you think, you become."</p>
      <div class="quote-source">Dhammapada</div>
      <div class="quote-tradition">Buddhism — Siddhartha Gautama</div>
    </div>
    <div class="quote-slide">
      <p class="quote-text">"Ahimsa is the highest form of Dharma. Ahimsa is the best form of self-restraint."</p>
      <div class="quote-source">Tattvartha Sutra</div>
      <div class="quote-tradition">Jainism — Umasvati</div>
    </div>
    <div class="quote-slide">
      <p class="quote-text">"Even kings and emperors with heaps of wealth and vast dominion cannot compare with an ant filled with the love of God."</p>
      <div class="quote-source">Guru Granth Sahib · 1167</div>
      <div class="quote-tradition">Sikhism — Guru Nanak Dev Ji</div>
    </div>
    <div class="quote-slide">
      <p class="quote-text">"Aham Brahmasmi — I am the ultimate reality. The individual self and the universal consciousness are one."</p>
      <div class="quote-source">Brihadaranyaka Upanishad · 1.4.10</div>
      <div class="quote-tradition">Vedanta — Ancient Rishis</div>
    </div>
  </div>
  <div class="quote-nav reveal">
    <button class="q-dot active" onclick="setQuote(0)"></button>
    <button class="q-dot" onclick="setQuote(1)"></button>
    <button class="q-dot" onclick="setQuote(2)"></button>
    <button class="q-dot" onclick="setQuote(3)"></button>
    <button class="q-dot" onclick="setQuote(4)"></button>
  </div>
</section>

<!-- SYMBOLS -->
<section id="symbols">
  <div class="symbols-header reveal">
    <span class="section-eyebrow">Sacred Geometry</span>
    <h2 class="section-title">Symbols of the <em>Dharmic</em> Universe</h2>
  </div>
  <div class="symbols-grid reveal">
    <div class="symbol-cell"><span class="sym-glyph">ॐ</span><span class="sym-name">Om</span></div>
    <div class="symbol-cell"><span class="sym-glyph">☸</span><span class="sym-name">Dharma Chakra</span></div>
    <div class="symbol-cell"><span class="sym-glyph">🔱</span><span class="sym-name">Trishul</span></div>
    <div class="symbol-cell"><span class="sym-glyph">🪷</span><span class="sym-name">Lotus</span></div>
    <div class="symbol-cell"><span class="sym-glyph">卍</span><span class="sym-name">Swastika</span></div>
    <div class="symbol-cell">
      <span class="sym-glyph" style="line-height:1; display:flex; align-items:center; justify-content:center;">
        <svg width="36" height="36" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
          <circle cx="50" cy="50" r="48" stroke="#C9933A" stroke-width="1.5" fill="none" opacity="0.7"/>
          <circle cx="50" cy="50" r="38" stroke="#C9933A" stroke-width="1" fill="none" opacity="0.5"/>
          <polygon points="50,8 88,72 12,72" stroke="#EDE5D4" stroke-width="1.5" fill="none" opacity="0.9"/>
          <polygon points="50,92 12,28 88,28" stroke="#EDE5D4" stroke-width="1.5" fill="none" opacity="0.9"/>
          <polygon points="50,18 80,65 20,65" stroke="#C9933A" stroke-width="1" fill="none" opacity="0.7"/>
          <polygon points="50,82 20,35 80,35" stroke="#C9933A" stroke-width="1" fill="none" opacity="0.7"/>
          <circle cx="50" cy="50" r="3" fill="#C9933A" opacity="0.9"/>
        </svg>
      </span>
      <span class="sym-name">Sri Yantra</span>
    </div>
    <div class="symbol-cell"><span class="sym-glyph">⚔</span><span class="sym-name">Khanda</span></div>
    <!-- Tantra Yantra symbol -->
    <div class="symbol-cell">
      <span class="sym-glyph" style="line-height:1; display:flex; align-items:center; justify-content:center;">
