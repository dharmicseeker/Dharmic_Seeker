---
import TopNav from "../components/TopNav.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

const { title, fullWidth = false } = Astro.props;
---


<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&family=Cinzel+Decorative:wght@700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>

  <body>
    <TopNav />

    <main class={fullWidth ? "full-content" : "content"}>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
/* ─── CUSTOM SCROLLBAR ─── */

body {
  overflow-y: overlay;
}

/* Chrome, Edge, Safari */
::-webkit-scrollbar {
  width: 14px; /* increased width */
}

::-webkit-scrollbar-track {
  background:
    rgba(7, 4, 10, 0.45); /* more translucent */

  backdrop-filter: blur(12px);

  border-left:
    1px solid rgba(255,255,255,0.05);
}

::-webkit-scrollbar-thumb {
  background:
    linear-gradient(
      to bottom,
      rgba(200,148,26,0.9),
      rgba(240,199,94,0.75)
    );

  border-radius: 999px;

  border:
    2px solid rgba(7,4,10,0.35);

  box-shadow:
    0 0 12px rgba(240,199,94,0.25);
}

::-webkit-scrollbar-thumb:hover {
  background:
    linear-gradient(
      to bottom,
      rgba(240,199,94,1),
      rgba(255,170,40,0.9)
    );

  box-shadow:
    0 0 18px rgba(240,199,94,0.45);
}

/* Firefox */
html {
  scrollbar-width: auto;

  scrollbar-color:
    rgba(200,148,26,0.9)
    rgba(7,4,10,0.45);
}

  .content {
    max-width: 1100px;
    margin: auto;
    padding-top: 130px;
    padding-left: 2rem;
    padding-right: 2rem;
    padding-bottom: 2rem;
  }

  .full-content {
    max-width: 100%;
    padding-top: 0rem;
    padding-left: 0rem;
    padding-right: 0rem;
    padding-bottom: 0rem;
  }
</style>

<script is:inline>
if (typeof window !== "undefined") {
  (function () {
    if (
      !window.chatbase ||
      window.chatbase("getState") !== "initialized"
    ) {
      window.chatbase = (...args) => {
        if (!window.chatbase.q) {
          window.chatbase.q = [];
        }
        window.chatbase.q.push(args);
      };

      window.chatbase = new Proxy(window.chatbase, {
        get(target, prop) {
          if (prop === "q") return target.q;
          return (...args) => target(prop, ...args);
        },
      });
    }

    const onLoad = function () {
      const script = document.createElement("script");
      script.src = "https://www.chatbase.co/embed.min.js";
      script.id = "5gUfFMR-ie_R7j1HOeo7g";
      script.domain = "www.chatbase.co";
      document.body.appendChild(script);
    };

    if (document.readyState === "complete") {
      onLoad();
    } else {
      window.addEventListener("load", onLoad);
    }
  })();
}
</script>